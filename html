async function copySelected(opts){
  opts=opts||{};
  const sh=active(); if(!sh) return false;
  const doArch=opts.archive!=null?!!opts.archive:(App.copyMode==='archive');

  // Co idzie do schowka + które wiersze ewentualnie → Archiwum
  let text='';
  let archiveRows=[];
  let copyLabel='';

  if(App.selRange){
    const s=App.selRange;
    const cells=(s.r1-s.r0+1)*(s.c1-s.c0+1);
    text=rangeTSV(sh);
    for(let r=s.r0;r<=s.r1;r++) archiveRows.push(r);
    copyLabel=cells===1?'komórkę':('zakres '+ (s.r1-s.r0+1)+'×'+(s.c1-s.c0+1));
  }else if(sh.selected.size){
    const idxs=[...sh.selected].sort((a,b)=>a-b);
    archiveRows=idxs;
    if(idxs.length===1 && App.activeCell && App.activeCell.r===idxs[0]){
      text=String(sh.rows[App.activeCell.r][App.activeCell.c]??'');
      copyLabel='komórkę';
    }else{
      text=rowsTSV(sh, idxs);
      copyLabel=idxs.length+' wierszy';
    }
  }else if(App.activeCell){
    text=String(sh.rows[App.activeCell.r][App.activeCell.c]??'');
    archiveRows=[App.activeCell.r];
    copyLabel='komórkę';
  }else{
    toast('Zaznacz komórkę lub wiersz'); return false;
  }

  const ok=await copyText(text);
  if(!ok){ toast('Nie udało się skopiować'); return false; }

  if(doArch){
    if(sh.name==='Archiwum'){
      toast('Skopiowano '+copyLabel+' (jesteś w Archiwum — bez przenoszenia)');
      return true;
    }
    // tryb → Archiwum: schowek = komórka/zakres, a CAŁE wiersze idą do Archiwum
    const uniq=[...new Set(archiveRows)].filter(ri=>ri>=0 && ri<sh.rows.length).sort((a,b)=>a-b);
    if(!uniq.length){ toast('Skopiowano '+copyLabel); return true; }
    sh.selected=new Set(uniq);
    markHandledToArchive({quiet:true, skipEmptyToast:true});
    toast('Skopiowano '+copyLabel+' i przeniesiono '+(uniq.length===1?'wiersz':'wiersze ('+uniq.length+')')+' → Archiwum');
    return true;
  }

  toast('Skopiowano '+copyLabel);
  return true;
}
function ensureTargetColumnsFromSource(source, target){
  if(!target.columns.length){
    target.columns=source.columns.slice();
    target.order=source.order.slice();
    target.visible=source.visible.slice();
    target.widths=source.widths.slice();
    return;
  }
  source.columns.forEach((name, sci)=>{
    if(target.columns.includes(name)) return;
    if(target.columns.length>=MAX){ toast('Limit '+MAX+' kolumn — nie dodano „'+name+'”'); return; }
    const tci=target.columns.length;
    target.columns.push(name);
    target.order.push(tci);
    target.visible.push(true);
    target.widths.push(source.widths[sci]||150);
    target.rows.forEach(r=>{ while(r.length<target.columns.length) r.push(''); });
  });
}
function mapRowByColumnNames(source, target, row){
  return target.columns.map(name=>{
    const sci=source.columns.indexOf(name);
    return sci>=0 ? (row[sci]??'') : '';
  });
}
function transferSelectedRows(opts){
  opts=opts||{};
  const move=!!opts.move;
  const targetId=opts.targetId||null;
  const sh=active();
  if(!sh||!sh.selected.size){ toast('Zaznacz wiersze'); return; }
  const idxs=[...sh.selected].sort((a,b)=>a-b);
  const n=idxs.length;
  pushUndo();

  let target;
  if(targetId){
    target=App.sheets.find(s=>s.id===targetId);
    if(!target){ toast('Nie znaleziono karty'); return; }
    ensureTargetColumnsFromSource(sh, target);
  }else{
    const seed={
      columns:sh.columns.slice(),
      order:sh.order.slice(),
      visible:sh.visible.slice(),
      widths:sh.widths.slice(),
      rows:idxs.map(i=>sh.rows[i].slice())
    };
    target=newSheet(move?'Przeniesione':'Wybrane', seed);
    idxs.forEach((oldRi,j)=>{
      if(sh.rowColors[oldRi]) target.rowColors[j]=sh.rowColors[oldRi];
      if(sh.rowStatus&&sh.rowStatus[oldRi]) target.rowStatus[j]=sh.rowStatus[oldRi];
    });
    App.sheets.push(target);
  }

  if(targetId){
    idxs.forEach(i=>{
      const destRi=target.rows.length;
      target.rows.push(mapRowByColumnNames(sh, target, sh.rows[i]));
      if(sh.rowColors[i]) target.rowColors[destRi]=sh.rowColors[i];
      if(sh.rowStatus&&sh.rowStatus[i]) target.rowStatus[destRi]=sh.rowStatus[i];
    });
  }

  if(move){
    deleteRowsByIndex(sh, idxs);
  }else{
    sh.selected.clear(); sh.last=-1;
  }
  clearSelRange(); App.anchorCell=null; App.activeCell=null;
  $('cellRef').textContent='—'; $('cellValue').textContent='';
  render();
  toast((move?'Przeniesiono ':'Skopiowano ')+n+' wierszy → „'+target.name+'”');
}
