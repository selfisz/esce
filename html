function addColumn(refCi, before){
  const sh=active(); if(!sh) return;
  if(sh.columns.length>=MAX){ toast('Limit '+MAX+' kolumn (A–Z)'); return; }
  const def='Kolumna '+letter(sh.columns.length);
  const name=prompt('Nazwa nowej kolumny:', def);
  if(name===null) return;
  pushUndo();
  const ci=sh.columns.length;
  sh.columns.push(name.trim()||def);
  sh.visible.push(true);
  sh.widths.push(140);
  const pos=refCi==null||refCi<0?-1:sh.order.indexOf(refCi);
  if(pos<0) sh.order.push(ci);
  else if(before) sh.order.splice(pos, 0, ci);
  else sh.order.splice(pos+1, 0, ci);
  sh.rows.forEach(r=>{ while(r.length<sh.columns.length) r.push(''); });
  if(!sh.rows.length) sh.rows.push(Array.from({length:sh.columns.length},()=>''));
  applyColorRules(sh); render();
  toast(before?'Wstawiono kolumnę przed':'Dodano kolumnę „'+sh.columns[ci]+'”');
}
function addRow(atRi, before){
