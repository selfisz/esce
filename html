function cellMatches(val, what, caseSens, whole){
  let v=String(val??''), w=String(what??'');
  if(!w) return false;
  if(!caseSens){ v=v.toLowerCase(); w=w.toLowerCase(); }
  return whole ? v===w : v.includes(w);
}
function findNext(fromDlg){
  const sh=active(); if(!sh||!sh.rows.length){ toast('Brak danych'); return; }
  const dlg=$('findDlg');
  const what=(dlg && !dlg.classList.contains('hidden') && dlg.querySelector('#findWhat')) ? dlg.querySelector('#findWhat').value : (App._findWhat||'');
  if(!what){ toast('Wpisz tekst do znalezienia'); return; }
  App._findWhat=what;
  const caseSens=!!(dlg&&dlg.querySelector('#findCase')&&dlg.querySelector('#findCase').checked);
  const whole=!!(dlg&&dlg.querySelector('#findWhole')&&dlg.querySelector('#findWhole').checked);
  const cols=visCols(sh);
  const idxs=sorted(sh, filtered(sh));
  let startR=App.findCursor.r||0, startC=App.findCursor.c||0;
  if(App.activeCell){ startR=App.activeCell.r; startC=App.activeCell.c+1; }
  const pairs=[];
  idxs.forEach(ri=>cols.forEach(ci=>pairs.push([ri,ci])));
  if(!pairs.length){ toast('Brak widocznych komórek'); return; }
  let startIdx=0;
  for(let i=0;i<pairs.length;i++){
    const [ri,ci]=pairs[i];
    if(ri>startR || (ri===startR && ci>=startC)){ startIdx=i; break; }
    startIdx=0;
  }
  for(let step=0; step<pairs.length; step++){
    const [ri,ci]=pairs[(startIdx+step)%pairs.length];
    if(cellMatches(sh.rows[ri][ci], what, caseSens, whole)){
      App.findCursor={r:ri,c:ci};
      sh.selected.clear(); sh.selected.add(ri); sh.last=ri;
      setActiveCell(sh,ri,ci);
      renderGrid();
      const cell=document.querySelector('td.cell-active');
      if(cell) cell.scrollIntoView({block:'center', inline:'nearest'});
      toast('Znaleziono: '+letter(sh.order.indexOf(ci))+(idxs.indexOf(ri)+1), 'copy');
      return;
    }
  }
  toast('Nie znaleziono');
}
function replaceAll(){
  const sh=active(); if(!sh) return;
  const dlg=$('findDlg');
  const what=dlg.querySelector('#findWhat').value;
  const withTxt=dlg.querySelector('#findWith').value;
  if(!what){ toast('Wpisz tekst do znalezienia'); return; }
  const caseSens=dlg.querySelector('#findCase').checked;
  const whole=dlg.querySelector('#findWhole').checked;
  const cols=visCols(sh);
  const idxs=sorted(sh, filtered(sh));
  let n=0;
  pushUndo();
  idxs.forEach(ri=>cols.forEach(ci=>{
    const cur=String(sh.rows[ri][ci]??'');
    if(!cellMatches(cur, what, caseSens, whole)) return;
    if(whole){ sh.rows[ri][ci]=withTxt; n++; return; }
    if(caseSens){ sh.rows[ri][ci]=cur.split(what).join(withTxt); n++; }
    else{
      const low=cur.toLowerCase(), needle=what.toLowerCase();
      let out='', from=0, p;
      while((p=low.indexOf(needle, from))>=0){
        out+=cur.slice(from,p)+withTxt; from=p+needle.length;
      }
      out+=cur.slice(from); sh.rows[ri][ci]=out; n++;
    }
  }));
  applyColorRules(sh); render();
  toast(n?('Zamieniono w '+n+' komórkach'):'Brak dopasowań');
}
function pasteMatrixAt(matrix, startR, startC){
  const sh=active(); if(!sh||!matrix||!matrix.length) return false;
  rememberPaste(matrix, 'Wklej tu');
  pushUndo();
  const needCols=Math.min(MAX, Math.max(...matrix.map(r=>r.length))+startC);
  while(sh.columns.length<needCols){
    const i=sh.columns.length;
    sh.columns.push('Kolumna '+letter(i));
    sh.order.push(i); sh.visible.push(true); sh.widths.push(150);
  }
  if(!sh.columns.length){ toast('Brak kolumn'); return false; }
  const endR=startR+matrix.length;
  while(sh.rows.length<endR) sh.rows.push(Array.from({length:sh.columns.length},()=>''));
  sh.rows.forEach(r=>{ while(r.length<sh.columns.length) r.push(''); });
  matrix.forEach((row,dr)=>{
    const ri=startR+dr;
    row.forEach((val,dc)=>{
      const ci=startC+dc;
      if(ci>=sh.columns.length) return;
      sh.rows[ri][ci]=val==null?'':String(val);
    });
  });
  applyColorRules(sh); render();
  toast('Wklejono '+matrix.length+'×'+(matrix[0]?.length||0)+' od '+letter(sh.order.indexOf(startC))+(startR+1));
  return true;
}
async function readClipboardMatrix(){
  try{
    const items=await navigator.clipboard.read();
    for(const it of items){
      if(it.types.includes('text/html')){
        const m=parseHtml(await (await it.getType('text/html')).text());
        if(m) return m;
      }
    }
    for(const it of items){
      if(it.types.includes('text/plain')){
        const raw=await (await it.getType('text/plain')).text();
        const m=parsePdfSmart(raw,{mode:'auto',cols:'auto'})||parseText(raw);
        if(m) return m;
      }
    }
  }catch(_){}
  return null;
}
