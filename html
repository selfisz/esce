function restoreSheetFromSnap(s){
  const sh=newSheet(s.name||'Karta', {
    columns:s.columns||[], rows:s.rows||[], order:s.order, visible:s.visible, widths:s.widths, showSums:s.showSums
  });
  if(s.id) sh.id=s.id;
  if(!sh.order.length && sh.columns.length) sh.order=sh.columns.map((_,i)=>i);
