<body>
<div class="app">
  <header class="chrome">
    <div class="chrome-top">
      <div class="mark">OT</div>
      <div>
        <input class="wb-title" id="wbTitle" value="Skoroszyt bez nazwy" spellcheck="false">
        <div class="wb-meta" id="wbMeta">V7.2 · Ctrl+C tryb · zapis · wstawianie</div>
      </div>
      <div class="chrome-actions">
        <span class="offline-pill" id="offlinePill" title="Brak sieci: CSP blokuje connect/fetch/CDN. Dane tylko w tej karcie przeglądarki (+ schematy w localStorage).">Offline · sandbox</span>
        <button class="btn ghost" id="btnSaveWb" type="button" title="Zapisz cały skoroszyt (JSON)">Zapisz</button>
        <button class="btn ghost" id="btnLoadWb" type="button" title="Wczytaj skoroszyt JSON">Wczytaj</button>
        <button class="btn primary" id="btnPaste" type="button">Wklej</button>
        <button class="btn ghost" id="btnPastePdf" type="button" title="Gdy z PDF leci tekst ze spacjami zamiast tabeli">Z PDF…</button>
        <button class="btn ghost" id="btnAppend" type="button">Dopisz</button>
        <button class="btn ghost" id="btnPasteHere" type="button" title="Wklej od aktywnej komórki / do zaznaczonych wierszy">Wklej tu</button>
        <div class="copy-toggle" id="copyToggle" title="Tryb Ctrl+C / przycisku Kopiuj">
          <button type="button" data-copy-mode="copy" id="btnCopyModeCopy">Ctrl+C</button>
          <button type="button" data-copy-mode="archive" id="btnCopyModeArch" class="arch">Ctrl+C → Archiwum</button>
        </div>
        <button class="btn ghost" id="btnCopy" type="button" title="Kopiuj zaznaczone (zgodnie z trybem obok)">Kopiuj</button>
        <div class="menu-wrap">
          <button class="btn ghost" id="btnPasteHist" type="button">Historia ▾</button>
          <div class="menu" id="pasteHistMenu"></div>
