function setRibbonTab(name, opts){
  const id=name||'dane';
  opts=opts||{};
  App.ribbonTab=id;
  document.querySelectorAll('.ribbon-tab').forEach(t=>t.classList.toggle('active', t.dataset.tab===id));
  document.querySelectorAll('.ribbon[data-panel]').forEach(p=>p.classList.toggle('active', p.dataset.panel===id));
  // Tylko gdy użytkownik celowo wchodzi w bazę / listę — nie przy Na później itd.
  if(opts.goBase){
    const reg=ensureRegistrySheet(true);
    refreshRegistryDerived(reg);
    if(!opts.silent) toast('★ Zobowiązani (dół) = BAZA ludzi — tu wklejasz zobowiązanych. Raporty do obróbki → karta Lista.');
    if(!opts.skipRender) render();
  }else if(opts.goLista){
    let lista=App.sheets.find(s=>s.name==='Lista');
    if(!lista){
      lista=App.sheets.find(s=>!isRegistrySheet(s) && s.name!==PARK_SHEET && s.name!=='Archiwum');
    }
    if(!lista){ lista=newSheet('Lista'); App.sheets.unshift(lista); }
    App.activeId=lista.id;
    if(!opts.silent) toast('Lista (dół) = tu wklejasz raporty do obróbki');
    if(!opts.skipRender) render();
  }
}
function renderSwatches(){
  const row=$('swatchRow'); if(!row) return;
  row.innerHTML='';
  ROW_PALETTE.forEach(p=>{
    const b=document.createElement('button');
    b.type='button'; b.className='swatch'; b.dataset.color=p.code; b.title=p.label;
    b.style.background=p.code?p.bg:'#fff';
    if(!p.code) b.style.boxShadow='inset 0 0 0 1px rgba(0,0,0,.25)';
    b.onclick=()=>{
      const sh=active(); if(!sh) return;
      const color=b.dataset.color||'';
      if(sh.selected.size){ colorRows([...sh.selected], color); toast(color?('Kolor: '+p.label):'Usunięto kolor'); return; }
      if(App.activeCell){ colorRows([App.activeCell.r], color); toast(color?('Kolor: '+p.label):'Usunięto kolor'); return; }
      toast('Zaznacz wiersze albo komórkę');
    };
    row.append(b);
  });
}
