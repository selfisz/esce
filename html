document.querySelectorAll('.swatch').forEach(sw=>sw.onclick=()=>{
  const sh=active();
  const color=sw.dataset.color;
  if(sh.selected.size){ colorRows([...sh.selected], color); toast(color?('Kolor zapisany'):'Usunięto kolor'); return; }
  if(App.activeCell){ colorRows([App.activeCell.r], color); toast(color?'Kolor wiersza aktywnej komórki':'Usunięto kolor'); return; }
  toast('PPM na wierszu albo zaznacz wiersze');
});
$('btnExport').onclick=()=>$('exportMenu').classList.toggle('open');
$('btnPdf').onclick=()=>{$('exportMenu').classList.remove('open'); toast('Zapisz jako PDF w oknie druku'); setTimeout(()=>window.print(),200);};
$('btnToExisting').onclick=()=>{const menu=$('sheetPickMenu'); menu.classList.toggle('open'); menu.innerHTML=''; const sh=active(); App.sheets.filter(s=>s.id!==sh.id).forEach(s=>{const b=document.createElement('button'); b.type='button'; b.textContent=s.name; b.onclick=()=>{sendSelectedToSheet(s.id); menu.classList.remove('open');}; menu.append(b);}); if(!menu.children.length){const b=document.createElement('button'); b.type='button'; b.textContent='Brak innych kart'; b.disabled=true; menu.append(b);}};
$('exportMenu').querySelectorAll('[data-export]').forEach(b=>b.onclick=()=>{
  const m=b.dataset.export; $('exportMenu').classList.remove('open');
  if(m==='copy-word'){ copyTableForWord(false, false); return; }
  if(m==='copy-plain'){ copyTableForWord(false, true); return; }
  if(m==='word-plain'){ exportWord(false, true); return; }
  if(m.startsWith('word')){ exportWord(m.includes('selected'), false); return; }
  if(m.startsWith('csv')) exportCsv(m.includes('selected'));
  else exportXls(m.includes('selected'));
});
document.onclick=e=>{
  if(!e.target.closest('.menu-wrap')){['exportMenu','sheetPickMenu','schemaMenu','pasteHistMenu'].forEach(id=>{const el=$(id); if(el) el.classList.remove('open');});}
  if(!e.target.closest('#colFilterPopup')&&!e.target.closest('.filter-btn')) $('colFilterPopup').classList.add('hidden');
  if(!e.target.closest('#ctxMenu')) hideCtx();
  if(e.target.id==='backdrop'){['rulesDlg','dedupDlg','groupDlg','schemaDlg','pastePdfDlg','findDlg','statusDlg'].forEach(id=>$(id).classList.add('hidden')); $('backdrop').classList.add('hidden');}
};
document.addEventListener('contextmenu', e=>{ if(e.target.closest('#dataGrid')) {/* handled per-row */} });
document.addEventListener('keydown', e=>{ if(e.key==='Escape') hideCtx(); });
document.addEventListener('paste', pasteEvent);
document.addEventListener('keydown', e=>{
  const sh=active(); if(!sh) return;
  if(e.key==='Escape'){sh.selected.clear(); App.activeCell=null; $('cellRef').textContent='—'; $('cellValue').textContent=''; hideCtx(); renderGrid();}
  
  // Precyzyjna blokada skrótów: ignoruje pola tekstowe i pasek formuły, ale pozwala działać checkboxom
  const isTextInput = e.target.matches('input:not([type="checkbox"]), textarea') || e.target.closest('#cellValue');

  if((e.ctrlKey||e.metaKey)&&e.key.toLowerCase()==='f'&&!isTextInput){e.preventDefault(); openFindDlg(); return;}
  if((e.ctrlKey||e.metaKey)&&e.key.toLowerCase()==='s'&&!isTextInput){e.preventDefault(); saveWorkbook(); return;}
  if((e.ctrlKey||e.metaKey)&&e.key.toLowerCase()==='a'&&!isTextInput&&document.activeElement.tagName!=='SELECT'){e.preventDefault(); sorted(sh,filtered(sh)).forEach(i=>sh.selected.add(i)); renderGrid();}
  if((e.ctrlKey||e.metaKey)&&e.key.toLowerCase()==='z'&&!isTextInput){e.preventDefault(); applyUndo();}
  
  if((e.ctrlKey||e.metaKey)&&e.key.toLowerCase()==='c'&&!isTextInput){
    const sel=window.getSelection();
    // Kopiuj zwykły tekst ze strony, jeśli nic nie zaznaczono w siatce
    if(sel&&String(sel).length&&!sh.selected.size&&!App.activeCell) return;
    
    e.preventDefault();
    
    // Auto-zaznaczanie: jeśli kliknąłeś komórkę, ale wiersz nie był odhaczony
    if(!sh.selected.size && App.activeCell){
      sh.selected.add(App.activeCell.r);
      sh.last = App.activeCell.r;
      renderGrid(); // odśwież widok, żeby było widać podświetlenie
    }
    
    if(sh.selected.size){
      copySelected();
    }
  }
});

loadSchemas(); loadCopyMode(); ensureBase(); render();
})();
