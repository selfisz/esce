[data-mode="dark"] .grid tbody tr.rc-red td,[data-mode="dark"] .grid tbody tr.selected.rc-red td{background:#450a0a!important}
[data-mode="dark"] .grid tbody tr.rc-blue td,[data-mode="dark"] .grid tbody tr.selected.rc-blue td{background:#172554!important}
[data-mode="dark"] .grid tbody tr.rc-purple td,[data-mode="dark"] .grid tbody tr.selected.rc-purple td{background:#2e1065!important}
