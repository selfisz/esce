function applySchema(schema, push){
  const sh=active(); if(!sh||!schema) return;
  if(push!==false) pushUndo();
  // map by column name when possible
  const nameToIdx={}; sh.columns.forEach((n,i)=>nameToIdx[n]=i);
  if(schema.columns && schema.columns.length){
    const newOrder=[]; schema.order.forEach(oldCi=>{
      const name=schema.columns[oldCi]; const idx=nameToIdx[name]; if(idx!=null && !newOrder.includes(idx)) newOrder.push(idx);
    });
    sh.columns.forEach((_,i)=>{if(!newOrder.includes(i)) newOrder.push(i);});
    sh.order=newOrder;
    sh.visible=sh.columns.map((_,i)=>{
      const name=sh.columns[i]; const oldCi=schema.columns.indexOf(name);
      return oldCi>=0 ? !!schema.visible[oldCi] : true;
    });
    sh.widths=sh.columns.map((_,i)=>{
      const name=sh.columns[i]; const oldCi=schema.columns.indexOf(name);
      return oldCi>=0 ? (schema.widths[oldCi]||150) : 150;
    });
    // remap filters/sort/rules by name
    const mappedFilters={};
    Object.entries(schema.colFilters||{}).forEach(([oldCi,f])=>{
      const name=schema.columns[+oldCi]; const idx=nameToIdx[name]; if(idx!=null) mappedFilters[idx]=f;
    });
    sh.colFilters=mappedFilters;
    if(schema.sort && schema.sort.i>=0){ const sn=schema.columns[schema.sort.i]; sh.sort={i:nameToIdx[sn]??-1, d:schema.sort.d||1}; }
    else sh.sort={i:-1,d:1};
    sh.colorRules=(schema.colorRules||[]).map(r=>Object.assign({},r));
  }else{
    sh.order=schema.order.slice(); sh.visible=schema.visible.slice(); sh.widths=schema.widths.slice();
    sh.sort=Object.assign({},schema.sort); sh.colFilters=JSON.parse(JSON.stringify(schema.colFilters||{}));
    sh.colorRules=JSON.parse(JSON.stringify(schema.colorRules||[]));
  }
  sh.filter=schema.filter||''; $('filterInput').value=sh.filter;
  App.wrap=!!schema.wrap; App.center=!!schema.center; if(schema.theme) App.theme=schema.theme;
  App.activeSchema=schema.name||App.activeSchema;
  applyColorRules(sh); render(); toast('Zastosowano schemat'+(schema.name?': '+schema.name:''));
}
