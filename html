  const sep=document.createElement('div'); sep.className='sep'; menu.append(sep);
  const clr=document.createElement('button'); clr.type='button'; clr.textContent='Wyczyść historię'; clr.style.color='var(--danger)';
  clr.onclick=()=>{ App.pasteHistory=[]; menu.classList.remove('open'); toast('Wyczyszczono historię'); };
  menu.append(clr);
}

function openStatusDlg(){
  const dlg=$('statusDlg'), bd=$('backdrop');
  const colors = [['yellow','Żółty'],['red','Czerwony'],['green','Zielony'],['blue','Niebieski'],['purple','Fioletowy'],['gray','Szary']];
  
  const renderList = () => {
    let html = '';
    App.statuses.forEach((st, i) => {
      const cOpts = colors.map(([c, n]) => `<option value="${c}" ${st.color===c?'selected':''}>${n}</option>`).join('');
      html += `<div style="display:flex;gap:6px;margin-bottom:6px;align-items:center;">
        <input type="text" value="${st.label}" data-idx="${i}" class="st-name" style="flex:1;border:1px solid var(--line);border-radius:6px;padding:4px 8px;background:var(--panel2);font-size:.8rem;">
        <select data-idx="${i}" class="st-color" style="border:1px solid var(--line);border-radius:6px;padding:4px;background:var(--panel2);font-size:.8rem;">${cOpts}</select>
        <button type="button" class="btn light sm danger btn-del-st" data-idx="${i}">×</button>
      </div>`;
    });
    dlg.querySelector('#stList').innerHTML = html || '<div style="color:var(--muted);font-size:.8rem;">Brak statusów</div>';
    
    dlg.querySelectorAll('.btn-del-st').forEach(b => b.onclick = (e) => {
      App.statuses.splice(+e.target.dataset.idx, 1);
      renderList();
    });
    dlg.querySelectorAll('.st-name').forEach(inp => inp.onchange = (e) => { App.statuses[+e.target.dataset.idx].label = e.target.value.trim(); });
    dlg.querySelectorAll('.st-color').forEach(sel => sel.onchange = (e) => { App.statuses[+e.target.dataset.idx].color = e.target.value; });
  };

  dlg.innerHTML=`<h3>Edycja statusów</h3>
    <p class="hint">Te statusy są widoczne w menu pod prawym przyciskiem myszy.</p>
    <div id="stList" style="max-height:40vh;overflow:auto;margin-bottom:10px;padding-right:4px;"></div>
    <button class="btn light sm" id="stAdd" type="button" style="width:100%;margin-bottom:12px;">＋ Dodaj nowy status</button>
    <div class="actions">
      <button class="btn primary" id="stClose" type="button" style="color:#fff">Zamknij i Zapisz</button>
    </div>`;
  
  dlg.classList.remove('hidden'); bd.classList.remove('hidden');
  renderList();
  
  dlg.querySelector('#stAdd').onclick = () => {
    App.statuses.push({id: 'st_'+Date.now(), label: 'Nowy status', color: 'gray'});
    renderList();
  };
  
  dlg.querySelector('#stClose').onclick = () => {
    dlg.classList.add('hidden'); bd.classList.add('hidden');
    renderGrid();
    toast('Zapisano statusy');
  };
}

