    more.style.opacity='0.85';
    more.onclick=(ev)=>{ ev.preventDefault(); ev.stopPropagation(); openRowContextMenu(e, ri, {expandColors:true}); };
    menu.append(more);
  }else if(expandColors){
    const less=document.createElement('button'); less.type='button';
    less.textContent='Zwiń kolory';
    less.style.opacity='0.85';
    less.onclick=(ev)=>{ ev.preventDefault(); ev.stopPropagation(); openRowContextMenu(e, ri, {expandColors:false}); };
    menu.append(less);
  }
  let sep=document.createElement('div'); sep.className='sep'; menu.append(sep);
  const stH=document.createElement('div'); stH.className='ctx-h'; stH.textContent='Status'; menu.append(stH);
  
  const bClear=document.createElement('button'); bClear.type='button'; bClear.textContent='Bez statusu';
  bClear.onclick=()=>{ setRowStatus([...sh.selected], ''); hideCtx(); toast('Usunięto status'); };
  menu.append(bClear);

  App.statuses.forEach(st=>{
    const b=document.createElement('button'); b.type='button'; 
    b.innerHTML=`<span class="badge-st c-${st.color}" style="margin:0 6px 0 0">${st.label.slice(0,1)}</span> ${st.label}`;
    b.onclick=()=>{ setRowStatus([...sh.selected], st.id); hideCtx(); toast('Status: '+st.label); };
    menu.append(b);
  });
  const bEdit=document.createElement('button'); bEdit.type='button'; bEdit.innerHTML='⚙️ Edytuj statusy...';
  bEdit.style.opacity='0.7'; bEdit.onclick=()=>{ hideCtx(); openStatusDlg(); };
  menu.append(bEdit);

  sep=document.createElement('div'); sep.className='sep'; menu.append(sep);
  const actions=[
    ['Wstaw wiersz powyżej', ()=>{ insertRowAt(ri, true); hideCtx(); }],
    ['Wstaw wiersz poniżej', ()=>{ insertRowAt(ri, false); hideCtx(); }],
    ['sep'],
    ['Kopiuj'+(App.copyMode==='archive'?' → Archiwum':''), async()=>{ await copySelected(); hideCtx(); }],
    ['Numeruj widok 1…N', ()=>{ renumberByView(); hideCtx(); }],
    ['Ukryj', ()=>{ hideSelectedRows(); hideCtx(); }],
    ['Obsłużone → Archiwum', ()=>{ markHandledToArchive(); hideCtx(); }],
    ['Usuń', ()=>{ deleteSelectedRows(); hideCtx(); }]
  ];
  actions.forEach(it=>{
    if(it[0]==='sep'){ const s=document.createElement('div'); s.className='sep'; menu.append(s); return; }
    const b=document.createElement('button'); b.type='button'; b.textContent=it[0];
    if(it[0]==='Usuń') b.style.color='var(--danger)';
    b.onclick=it[1]; menu.append(b);
  });
  menu.classList.add('open');
  placeCtxMenu(e);
}
function placeCtxMenu(e){
  const menu=$('ctxMenu');
  menu.classList.add('open');
  const pad=8; let x=e.clientX, y=e.clientY;
  menu.style.left='0px'; menu.style.top='0px';
  const w=menu.offsetWidth, h=menu.offsetHeight;
  if(x+w>window.innerWidth-pad) x=window.innerWidth-w-pad;
  if(y+h>window.innerHeight-pad) y=window.innerHeight-h-pad;
  menu.style.left=Math.max(pad,x)+'px'; menu.style.top=Math.max(pad,y)+'px';
}
function openHeaderContextMenu(e, ci){
