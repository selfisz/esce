document.addEventListener('keydown', e=>{
  if(isPanicOn() && e.key!=='Escape'){ e.preventDefault(); return; }
  const sh=active(); if(!sh) return;
  const typing=isGridTypingTarget(e.target) || App.editing;

  if(e.key==='Escape'){
    e.preventDefault();
    if(isPanicOn()){
      if(noteEscBurst(true)) hidePanicCover();
      return;
    }
    if(App.editing){ endEdit(false); return; }
    // zamknij otwarte dialogi jednym Esc
    const openDlg=['rulesDlg','dedupDlg','groupDlg','compareDlg','schemaDlg','pastePdfDlg','findDlg','statusDlg','dossierDlg'].find(id=>{const el=$(id); return el&&!el.classList.contains('hidden');});
    if(openDlg){ $(openDlg).classList.add('hidden'); $('backdrop').classList.add('hidden'); return; }
    hideCtx();
    ['exportMenu','sheetPickMenu','sheetMoveMenu','schemaMenu','pasteHistMenu','regSysMenu'].forEach(id=>{const el=$(id); if(el) el.classList.remove('open');});
    if(noteEscBurst(false)){ showPanicCover(); return; }
    sh.selected.clear(); App.activeCell=null; clearSelRange(); App.anchorCell=null;
    $('cellRef').textContent='—'; $('cellValue').textContent=''; renderGrid();
    return;
  }

  if((e.ctrlKey||e.metaKey)&&e.key.toLowerCase()==='f'&&!typing){e.preventDefault(); openFindDlg(); return;}
  if((e.ctrlKey||e.metaKey)&&e.key.toLowerCase()==='s'&&!typing){e.preventDefault(); saveWorkbook(); return;}
  if((e.ctrlKey||e.metaKey)&&e.key.toLowerCase()==='a'&&!typing&&document.activeElement.tagName!=='SELECT'){
    e.preventDefault();
    const cols=visCols(sh); const idxs=sorted(sh,filtered(sh));
    idxs.forEach(i=>sh.selected.add(i));
    if(idxs.length && cols.length) setSelRange(idxs[0], cols[0], idxs[idxs.length-1], cols[cols.length-1]);
    renderGrid();
    return;
  }
  if((e.ctrlKey||e.metaKey)&&e.key.toLowerCase()==='z'&&!typing){e.preventDefault(); applyUndo(); return;}

  if((e.ctrlKey||e.metaKey)&&e.key.toLowerCase()==='c'&&!typing){
    const sel=window.getSelection();
    if(sel&&String(sel).length&&!sh.selected.size&&!App.activeCell&&!App.selRange) return;
    e.preventDefault();
    copySelected();
    return;
  }

  if(typing) return;

  // Nawigacja / edycja Excel-lite
  if(['ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.key)){
    e.preventDefault();
    if(!App.activeCell){
      const cols=visCols(sh); const idxs=sorted(sh,filtered(sh));
      if(cols.length&&idxs.length) focusCell(idxs[0], cols[0], false);
    }else{
      const dr=e.key==='ArrowUp'?-1:e.key==='ArrowDown'?1:0;
      const dc=e.key==='ArrowLeft'?-1:e.key==='ArrowRight'?1:0;
      moveActive(dr,dc,e.shiftKey);
      return;
    }
    renderGrid(); scrollActiveIntoView();
    return;
  }
  if(e.key==='Tab'){
    e.preventDefault();
    if(!App.activeCell){
      const cols=visCols(sh); const idxs=sorted(sh,filtered(sh));
      if(cols.length&&idxs.length){ focusCell(idxs[0], cols[0], false); renderGrid(); }
    }else moveActive(0, e.shiftKey?-1:1, false);
    return;
  }
  if(e.key==='Enter'){
    e.preventDefault();
    if(!App.activeCell) return;
    if(e.shiftKey) moveActive(-1,0,false);
    else beginEdit(App.activeCell.r, App.activeCell.c);
    return;
  }
  if(e.key==='F2'){
    e.preventDefault();
    if(App.activeCell) beginEdit(App.activeCell.r, App.activeCell.c);
    return;
  }
  if(e.key==='Delete' || e.key==='Backspace'){
    e.preventDefault();
    if(App.selRange) clearRangeCells();
    else if(App.activeCell){
      setSelRange(App.activeCell.r, App.activeCell.c, App.activeCell.r, App.activeCell.c);
      clearRangeCells();
    }
    return;
  }
  // Start edycji przez wpisywanie
  if(e.key.length===1 && !e.ctrlKey && !e.metaKey && !e.altKey){
    if(!App.activeCell){
      const cols=visCols(sh); const idxs=sorted(sh,filtered(sh));
      if(cols.length&&idxs.length) focusCell(idxs[0], cols[0], false);
    }
    if(App.activeCell){
      e.preventDefault();
      beginEdit(App.activeCell.r, App.activeCell.c, e.key);
    }
  }
});

