<script>
(function(){
'use strict';
const MAX=26, LETTERS=Array.from({length:MAX},(_,i)=>String.fromCharCode(65+i));
const SCHEMA_KEY='ots_schemas_v1';
const COPY_MODE_KEY='ots_copy_mode_v1';
const PASTE_HIST_MAX=12;

const DEFAULT_STATUSES = [
  {id:'todo', label:'Do zrobienia', color:'yellow'},
  {id:'windykacja', label:'Windykacja', color:'red'},
  {id:'ok', label:'Załatwione', color:'green'},
  {id:'czekaj', label:'Czekaj', color:'blue'}
];
const $=id=>document.getElementById(id);

const uid=()=>'s'+Math.random().toString(36).slice(2,9);
const letter=i=>LETTERS[i]||'?';
const norm=v=>String(v==null?'':v).replace(/\u00a0/g,' ').trim();
const toNum=v=>{const s=norm(v).replace(/\s/g,'').replace(',','.'); const n=parseFloat(s); return (s!==''&&!isNaN(n)&&/^-?\d+([.]\d+)?$/.test(s))?n:null;};
function toast(msg, kind){
  const t=$('toast'); t.textContent=msg; t.classList.add('show');
  t.classList.toggle('copy', kind==='copy');
  clearTimeout(t._x); t._x=setTimeout(()=>{t.classList.remove('show'); t.classList.remove('copy');}, kind==='copy'?1100:1800);
}
async function copyText(text){
  const s=String(text??'');
  try{ await navigator.clipboard.writeText(s); return true; }
  catch(_){
    try{
      const ta=document.createElement('textarea'); ta.value=s; ta.style.cssText='position:fixed;left:-9999px;top:0';
      document.body.appendChild(ta); ta.select(); const ok=document.execCommand('copy'); ta.remove(); return ok;
    }catch(__){ return false; }
  }
}
function measureTextWidth(text, font){
  const c=measureTextWidth._ctx||(measureTextWidth._ctx=document.createElement('canvas').getContext('2d'));
  c.font=font||'14px "Segoe UI",system-ui,sans-serif';
  return c.measureText(String(text??'')).width;
}
function autoFitColumns(){
  const sh=active(); if(!sh||!sh.columns.length){ toast('Brak kolumn'); return; }
  pushUndo();
  const cols=visCols(sh); const idxs=sorted(sh, filtered(sh));
  const headFont='650 13px "Segoe UI",system-ui,sans-serif';
  const cellFont='14px "Segoe UI",system-ui,sans-serif';
  cols.forEach(ci=>{
    let max=measureTextWidth(sh.columns[ci], headFont)+56;
    const sample=idxs.length>800?idxs.filter((_,i)=>i%Math.ceil(idxs.length/800)===0):idxs;
    sample.forEach(ri=>{ max=Math.max(max, measureTextWidth(sh.rows[ri][ci], cellFont)+28); });
    sh.widths[ci]=Math.min(480, Math.max(72, Math.ceil(max)));
  });
  App.wrap=true;
  render();
  toast('Autodopasowano kolumny (+ zawijanie)');
}
/** Po sortowaniu: LP (lub 1. kolumna) = 1…N w kolejności na ekranie. */
function renumberByView(){
  const sh=active(); if(!sh||!sh.rows.length){ toast('Brak wierszy'); return; }
  const idxs=sorted(sh, filtered(sh));
  if(!idxs.length){ toast('Brak widocznych wierszy'); return; }
  let lpCi=sh.columns.findIndex(c=>/^LP$/i.test(String(c).trim()));
  if(lpCi<0) lpCi=0;
  pushUndo();
  idxs.forEach((ri,i)=>{ sh.rows[ri][lpCi]=String(i+1); });
  applyColorRules(sh);
  render();
  toast('Ponumerowano 1…'+idxs.length+' (kolumna „'+sh.columns[lpCi]+'”)');
}
/** Usuń kolory wierszy / reguły i włącz zwykły wygląd tabeli (nagłówek bez tła). */
function clearFills(){
  const sh=active(); if(!sh) return;
  pushUndo();
  sh.rowColors={}; sh.marks={}; sh.colorRules=[]; sh._ruleColors={};
  App.plain=true;
  render();
  toast('Usunięto wypełnienie — zwykła tabela (nagłówek bez kolorów)');
}
function togglePlainView(){
  App.plain=!App.plain;
  render();
  toast(App.plain?'Tryb zwykłej tabeli':'Tryb z kolorami');
}
function colorRows(indices, color){
  const sh=active(); if(!sh) return;
  indices.forEach(ri=>{ if(!color) delete sh.rowColors[ri]; else sh.rowColors[ri]=color; });
  renderGrid();
}
function hideCtx(){ const m=$('ctxMenu'); if(m) m.classList.remove('open'); }
function openRowContextMenu(e, ri){
  e.preventDefault(); e.stopPropagation();
  const sh=active(); if(!sh) return;
  if(!sh.selected.has(ri)){ sh.selected.clear(); sh.selected.add(ri); sh.last=ri; renderGrid(); }
  const menu=$('ctxMenu');
  const n=sh.selected.size;
  const colors=[
    ['','Bez koloru','#fff'],['yellow','Żółty','#eab308'],['green','Zielony','#22c55e'],
    ['red','Czerwony','#ef4444'],['blue','Niebieski','#3b82f6'],['purple','Fiolet','#a855f7'],['gray','Szary','#94a3b8']
  ];
  menu.innerHTML='<div class="ctx-h">Wiersz'+(n>1?'e ('+n+')':'')+' — PPM</div>';
  colors.forEach(([code,label,bg])=>{
    const b=document.createElement('button'); b.type='button';
    b.innerHTML='<span class="dot" style="background:'+bg+'"></span>'+label;
    b.onclick=()=>{ colorRows([...sh.selected], code); hideCtx(); toast(code?('Kolor: '+label):'Usunięto kolor'); };
    menu.append(b);
  });
  let sep=document.createElement('div'); sep.className='sep'; menu.append(sep);
  const stH=document.createElement('div'); stH.className='ctx-h'; stH.textContent='Status'; menu.append(stH);
  
  const bClear=document.createElement('button'); bClear.type='button'; bClear.textContent='Bez statusu';
  bClear.onclick=()=>{ setRowStatus([...sh.selected], ''); hideCtx(); toast('Usunięto status'); };
  menu.append(bClear);

  App.statuses.forEach(st=>{
    const b=document.createElement('button'); b.type='button'; 
    b.innerHTML=`<span class="badge-st c-${st.color}" style="margin:0 6px 0 0">${st.label.slice(0,1)}</span> ${st.label}`;
    b.onclick=()=>{ setRowStatus([...sh.selected], st.id); hideCtx(); toast('Status: '+st.label); };
    menu.append(b);
  });
  const bEdit=document.createElement('button'); bEdit.type='button'; bEdit.innerHTML='⚙️ Edytuj statusy...';
  bEdit.style.opacity='0.7'; bEdit.onclick=()=>{ hideCtx(); openStatusDlg(); };
  menu.append(bEdit);

  sep=document.createElement('div'); sep.className='sep'; menu.append(sep);
  const actions=[
    ['Wstaw wiersz powyżej', ()=>{ insertRowAt(ri, true); hideCtx(); }],
    ['Wstaw wiersz poniżej', ()=>{ insertRowAt(ri, false); hideCtx(); }],
    ['sep'],
    ['Kopiuj'+(App.copyMode==='archive'?' → Archiwum':''), async()=>{ await copySelected(); hideCtx(); }],
    ['Numeruj widok 1…N', ()=>{ renumberByView(); hideCtx(); }],
    ['Ukryj', ()=>{ hideSelectedRows(); hideCtx(); }],
    ['Obsłużone → Archiwum', ()=>{ markHandledToArchive(); hideCtx(); }],
    ['Usuń', ()=>{ deleteSelectedRows(); hideCtx(); }]
  ];
  actions.forEach(it=>{
    if(it[0]==='sep'){ const s=document.createElement('div'); s.className='sep'; menu.append(s); return; }
    const b=document.createElement('button'); b.type='button'; b.textContent=it[0];
    if(it[0]==='Usuń') b.style.color='var(--danger)';
    b.onclick=it[1]; menu.append(b);
  });
  menu.classList.add('open');
  placeCtxMenu(e);
}
function placeCtxMenu(e){
  const menu=$('ctxMenu');
  menu.classList.add('open');
  const pad=8; let x=e.clientX, y=e.clientY;
  menu.style.left='0px'; menu.style.top='0px';
  const w=menu.offsetWidth, h=menu.offsetHeight;
  if(x+w>window.innerWidth-pad) x=window.innerWidth-w-pad;
  if(y+h>window.innerHeight-pad) y=window.innerHeight-h-pad;
  menu.style.left=Math.max(pad,x)+'px'; menu.style.top=Math.max(pad,y)+'px';
}
function openHeaderContextMenu(e, ci){
  e.preventDefault(); e.stopPropagation();
  const sh=active(); if(!sh||ci<0) return;
  hideCtx();
  const menu=$('ctxMenu');
  const name=sh.columns[ci]||('Kolumna '+ci);
  menu.innerHTML='';
  const h=document.createElement('div'); h.className='ctx-h'; h.textContent='Nagłówek: '+name; menu.append(h);
  const items=[
    ['Zmień nazwę…', ()=>{ hideCtx(); renameColumn(ci); }],
    ['Kopiuj nazwę', async()=>{ await copyText(name); hideCtx(); toast('Skopiowano nazwę', 'copy'); }],
    ['sep'],
    ['Sortuj A→Z / rosnąco', ()=>{ pushUndo(); sh.sort={i:ci,d:1}; hideCtx(); renderGrid(); }],
    ['Sortuj Z→A / malejąco', ()=>{ pushUndo(); sh.sort={i:ci,d:-1}; hideCtx(); renderGrid(); }],
    ['Filtr kolumny…', ()=>{ hideCtx(); const th=[...document.querySelectorAll('#gridHead th')].find(t=>t.querySelector('.title')?.textContent===sh.columns[ci]); openColFilter(ci, th?.querySelector('.filter-btn')||th||document.body); }],
    ['sep'],
    ['Wstaw kolumnę przed', ()=>{ hideCtx(); addColumn(ci, true); }],
    ['Wstaw kolumnę po', ()=>{ hideCtx(); addColumn(ci, false); }],
    ['Ukryj kolumnę', ()=>{ pushUndo(); sh.visible[ci]=false; hideCtx(); render(); toast('Ukryto kolumnę'); }],
    ['Dopasuj tę kolumnę', ()=>{
      pushUndo();
      const idxs=sorted(sh,filtered(sh));
      let max=measureTextWidth(sh.columns[ci],'650 13px "Segoe UI",system-ui,sans-serif')+56;
      idxs.forEach(ri=>{ max=Math.max(max, measureTextWidth(sh.rows[ri][ci],'14px "Segoe UI",system-ui,sans-serif')+28); });
      sh.widths[ci]=Math.min(480, Math.max(72, Math.ceil(max)));
      hideCtx(); renderGrid(); toast('Dopasowano kolumnę');
    }],
    ['sep'],
    ['Usuń kolumnę', ()=>{ hideCtx(); deleteColumn(ci); }]
  ];
  items.forEach(it=>{
    if(it[0]==='sep'){ const s=document.createElement('div'); s.className='sep'; menu.append(s); return; }
    const b=document.createElement('button'); b.type='button'; b.textContent=it[0];
    if(it[0]==='Usuń kolumnę') b.style.color='var(--danger)';
    b.onclick=it[1]; menu.append(b);
  });
  placeCtxMenu(e);
}
function selectAllText(el){const r=document.createRange(); r.selectNodeContents(el); const s=window.getSelection(); s.removeAllRanges(); s.addRange(r);}

function emptyFilter(){return {mode:'any', text:'', min:'', max:''};}
function newSheet(name, seed){
  return {id:uid(), name:name||'Robocza', columns:seed?.columns?.slice()||[], rows:seed?.rows?.map(r=>r.slice())||[],
    order:seed?.order?.slice()||[], visible:seed?.visible?.slice()||[], widths:seed?.widths?.slice()||[],
    sort:{i:-1,d:1}, filter:'', colFilters:{}, selected:new Set(), hiddenRows:new Set(), last:-1,
    rowColors:{}, marks:{}, rowStatus:{}, colorRules:[], activeCol:-1, _renaming:false, showSums:seed?.showSums??false};
}
function ensureHidden(sh){
  if(!sh.hiddenRows || !(sh.hiddenRows instanceof Set)) sh.hiddenRows=new Set(Array.isArray(sh.hiddenRows)?sh.hiddenRows:[]);
}
function ensureRowStatus(sh){ if(!sh.rowStatus || typeof sh.rowStatus!=='object') sh.rowStatus={}; }
function remapIndexMap(map, deletedAsc){
  const del=new Set(deletedAsc); const next={};
  Object.keys(map||{}).forEach(k=>{
    const i=+k; if(del.has(i)) return;
    next[i-deletedAsc.filter(d=>d<i).length]=map[k];
  });
  return next;
}
function remapHiddenSet(set, deletedAsc){
  const del=new Set(deletedAsc); const next=new Set();
  set.forEach(i=>{ if(del.has(i)) return; next.add(i-deletedAsc.filter(d=>d<i).length); });
  return next;
}
function shiftIndexMapUp(map, at){
  const next={};
  Object.keys(map||{}).forEach(k=>{ const i=+k; next[i>=at?i+1:i]=map[k]; });
  return next;
}
function shiftHiddenSetUp(set, at){
  const next=new Set();
  set.forEach(i=>next.add(i>=at?i+1:i));
  return next;
}
function deleteRowsByIndex(sh, idxs){
  const deleted=[...idxs].sort((a,b)=>a-b);
  for(let k=deleted.length-1;k>=0;k--) sh.rows.splice(deleted[k],1);
  ensureHidden(sh); ensureRowStatus(sh);
  sh.hiddenRows=remapHiddenSet(sh.hiddenRows, deleted);
  sh.rowColors=remapIndexMap(sh.rowColors, deleted);
  sh.marks=remapIndexMap(sh.marks, deleted);
  sh.rowStatus=remapIndexMap(sh.rowStatus, deleted);
  sh.selected.clear(); sh.last=-1;
  applyColorRules(sh);
  return deleted.length;
}
function setRowStatus(indices, status){
  const sh=active(); if(!sh) return;
  ensureRowStatus(sh);
  indices.forEach(ri=>{ if(!status) delete sh.rowStatus[ri]; else sh.rowStatus[ri]=status; });
  renderGrid();
}
function insertRowAt(ri, before){
  const sh=active(); if(!sh) return;
  if(!sh.columns.length){ toast('Najpierw dodaj kolumnę albo wklej dane'); return; }
  const at=Math.max(0, Math.min(before?ri:ri+1, sh.rows.length));
  pushUndo();
  ensureHidden(sh); ensureRowStatus(sh);
  sh.rows.splice(at, 0, Array.from({length:sh.columns.length},()=>''));
  sh.rowColors=shiftIndexMapUp(sh.rowColors, at);
  sh.marks=shiftIndexMapUp(sh.marks, at);
  sh.rowStatus=shiftIndexMapUp(sh.rowStatus, at);
  sh.hiddenRows=shiftHiddenSetUp(sh.hiddenRows, at);
  const ns=new Set(); sh.selected.forEach(i=>ns.add(i>=at?i+1:i)); sh.selected=ns;
  if(sh.last>=at) sh.last++;
  if(App.activeCell&&App.activeCell.r>=at) App.activeCell.r++;
  applyColorRules(sh); render();
  toast(before?'Wstawiono wiersz powyżej':'Wstawiono wiersz poniżej');
}

const App={workbook:'Skoroszyt bez nazwy', sheets:[], activeId:null, wrap:false, center:false, plain:false, theme:'navy', dark:false,
  dragCol:null, dragSheet:null, filterCol:null, activeCell:null, schemas:[], undoStack:[], activeSchema:null,
  pasteHistory:[], findCursor:{r:0,c:0}, copyMode:'copy', statuses:JSON.parse(JSON.stringify(DEFAULT_STATUSES))};

function active(){return App.sheets.find(s=>s.id===App.activeId);}
function ensureBase(){if(!App.sheets.length){const s=newSheet('Dane'); App.sheets.push(s); App.activeId=s.id;}}
function loadSchemas(){try{App.schemas=JSON.parse(localStorage.getItem(SCHEMA_KEY)||'[]')||[];}catch(_){App.schemas=[];}}
function saveSchemas(){try{localStorage.setItem(SCHEMA_KEY, JSON.stringify(App.schemas));}catch(_){toast('Nie zapisano schematów (localStorage)');}}

function snapshotView(){
