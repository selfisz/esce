.grid tbody tr.rc-red td,.grid tbody tr.selected.rc-red td,.grid tbody tr.rc-red:hover td{background:#fee2e2!important}
.grid tbody tr.rc-blue td,.grid tbody tr.selected.rc-blue td,.grid tbody tr.rc-blue:hover td{background:#dbeafe!important}
