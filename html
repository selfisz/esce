.menu-wrap{position:relative}.menu{display:none;position:absolute;right:0;top:calc(100% + 6px);min-width:230px;background:var(--panel);color:var(--text);border:1px solid var(--line);border-radius:10px;box-shadow:var(--shadow);padding:6px;z-index:40}
.menu.open{display:block}.menu button,.menu .mi{width:100%;text-align:left;border:0;background:transparent;color:var(--text);padding:8px 10px;border-radius:8px;font:inherit;cursor:pointer;display:block}
