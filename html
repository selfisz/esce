.grid.wrap .cell{white-space:normal;overflow:visible;word-break:break-word}
.grid.center .cell,.grid.center .th-inner{text-align:center;justify-content:center}
.grid tbody tr:nth-child(even) td{background:var(--zebra)}.grid tbody tr:hover td{background:var(--soft)}
.grid tbody tr.selected td{background:var(--sel)!important}.grid td.cell-active{outline:2px solid var(--accent);outline-offset:-2px}
