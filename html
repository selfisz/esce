function parkingWaitPeselSet(){
  const set=new Set();
  const park=getParkingSheet();
  if(!park) return set;
  const pci=park.columns.indexOf('PESEL');
  const sci=park.columns.indexOf('Status');
  if(pci<0) return set;
  park.rows.forEach(r=>{
