#colFilterPopup .cf-sep{height:1px;background:var(--line);margin:10px 0}
#colFilterPopup .cf-sub{font-size:.72rem;color:var(--muted);margin:0 0 4px;font-weight:650}
.dlg{left:50%;top:50%;transform:translate(-50%,-50%);width:min(440px,92vw);max-height:80vh;overflow:auto}
.dlg h3{margin:0 0 10px;font-size:1rem}.dlg .row{display:grid;gap:6px;margin-bottom:10px}.dlg .row label{font-size:.75rem;color:var(--muted)}
.dlg textarea{width:100%;min-height:160px;resize:vertical;border:1px solid var(--line);border-radius:8px;padding:8px;font:inherit;font-size:.82rem;font-family:var(--mono);background:var(--panel2);color:var(--text);box-sizing:border-box}
.dlg .hint{font-size:.78rem;color:var(--muted);line-height:1.4;margin:0 0 10px}
.dlg .row input,.dlg .row select{border:1px solid var(--line);border-radius:8px;padding:8px;background:var(--panel2)}
.dlg .actions{display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap;margin-top:8px}
.backdrop{position:fixed;inset:0;background:rgba(10,16,28,.45);z-index:45}
.hidden{display:none!important}
.ctx{position:fixed;z-index:70;min-width:200px;max-width:min(280px,92vw);max-height:min(70vh,560px);overflow:auto;background:var(--panel);color:var(--text);border:1px solid var(--line);border-radius:10px;box-shadow:var(--shadow);padding:6px;display:none}
.ctx.open{display:block}
.grid.virt-mode tbody tr:not(.virt-spacer){height:34px}
.grid.virt-mode tbody tr:not(.virt-spacer) .cell{white-space:nowrap!important;overflow:hidden!important;text-overflow:ellipsis;max-height:34px}
.ctx .ctx-h{font-size:.72rem;color:var(--muted);padding:4px 10px 6px;font-weight:650}
.ctx button{width:100%;text-align:left;border:0;background:transparent;color:var(--text);padding:8px 10px;border-radius:8px;font:inherit;cursor:pointer;display:flex;align-items:center;gap:8px}
.ctx button:hover{background:var(--panel2)}
.ctx .sep{height:1px;background:var(--line);margin:4px 0}
.ctx .dot{width:12px;height:12px;border-radius:99px;border:1px solid var(--line);flex-shrink:0}
.toast{position:fixed;right:16px;bottom:56px;background:var(--chrome);color:#fff;padding:10px 14px;border-radius:10px;box-shadow:var(--shadow);font-size:.82rem;z-index:60;opacity:0;transform:translateY(8px);transition:.2s}
.toast.show{opacity:1;transform:none}
.badge-st{font-size:.65rem;padding:1px 5px;border-radius:4px;margin-left:4px;font-weight:700;vertical-align:middle}
.st-c-yellow{box-shadow:inset 3px 0 0 #eab308!important}.badge-st.c-yellow{background:#fef3c7;color:#854d0e}
.st-c-red{box-shadow:inset 3px 0 0 #ef4444!important}.badge-st.c-red{background:#fee2e2;color:#991b1b}
.st-c-green{box-shadow:inset 3px 0 0 #22c55e!important}.badge-st.c-green{background:#dcfce7;color:#166534}
.st-c-blue{box-shadow:inset 3px 0 0 #3b82f6!important}.badge-st.c-blue{background:#dbeafe;color:#1e40af}
.st-c-purple{box-shadow:inset 3px 0 0 #a855f7!important}.badge-st.c-purple{background:#f3e8ff;color:#6b21a8}
.st-c-gray{box-shadow:inset 3px 0 0 #94a3b8!important}.badge-st.c-gray{background:#f1f5f9;color:#334155}
.th-inner .sort{cursor:pointer}.th-inner .sort:hover{opacity:1}
@media(max-width:980px){.main{grid-template-columns:1fr}.sidebar{border-left:0;border-top:1px solid var(--line);max-height:190px}}
@media print{body{background:#fff!important;color:#000!important;overflow:visible}.chrome,.toolbar,.sidebar,.sheetbar,.statusbar,.formulabar,.chipbar,.toast,.popup,.dlg,.backdrop,.menu,.resize,.filter-btn,.ribbon-tabs{display:none!important}.app{display:block;height:auto}.main{display:block}.workspace{padding:0}.grid-wrap{overflow:visible;border:0;box-shadow:none}.print-head{display:block!important;margin:0 0 12px}table.grid{width:100%;font-size:10pt}.grid thead th{position:static;background:#111!important;color:#fff!important;-webkit-print-color-adjust:exact;print-color-adjust:exact}}
.print-head{display:none}.print-head h1{margin:0;font-size:18pt}.print-head p{margin:4px 0 0;color:#444;font-size:10pt}

.panic-cover{position:fixed;inset:0;z-index:9999;background:#f4f1e8;overflow:auto;font-family:"Times New Roman",Times,serif;color:#111}
.panic-cover[hidden]{display:none!important}
.panic-doc{max-width:820px;margin:28px auto 60px;padding:28px 36px;background:#fffef8;border:1px solid #cbb;box-shadow:0 8px 30px rgba(0,0,0,.12)}
.panic-seal{display:inline-block;border:2px solid #333;padding:4px 10px;font-size:.75rem;letter-spacing:.08em;text-transform:uppercase;margin-bottom:18px}
.panic-doc h1{text-align:center;font-size:1.6rem;margin:8px 0;font-weight:700}
.panic-doc h2{text-align:center;font-size:1.15rem;margin:6px 0 18px;font-weight:700}
.panic-sub,.panic-meta{text-align:center;margin:0 0 8px;font-size:.95rem}
.panic-meta{color:#444;font-size:.82rem;margin-bottom:22px}
.panic-body{font-size:.92rem;line-height:1.55;text-align:justify}
.panic-body h3{font-size:1rem;margin:18px 0 8px;text-align:center}
.panic-body p{margin:0 0 10px;text-indent:1.5em}
.panic-hint{margin-top:28px;text-align:center;font-size:.75rem;color:#888;font-family:system-ui,sans-serif}
.dossier-block{border:1px solid var(--line);border-radius:10px;padding:10px;margin:0 0 10px;background:var(--panel2)}
.dossier-block h4{margin:0 0 8px;font-size:.85rem}
.dossier-kv{display:grid;grid-template-columns:120px 1fr;gap:4px 8px;font-size:.8rem}
.dossier-kv b{color:var(--muted);font-weight:650}
.dossier-list{max-height:180px;overflow:auto;font-size:.78rem}
.dossier-list div{padding:6px 0;border-bottom:1px solid var(--line)}

.sheet.sheet-base{background:color-mix(in srgb,var(--accent) 18%,var(--panel));font-weight:700}
.sheet.sheet-base.active{box-shadow:inset 0 -3px 0 var(--accent)}
.sheet.sheet-park{font-style:italic}

