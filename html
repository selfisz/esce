  // 0) PDF AUM (rachunki bankowe po PESEL)
  if(mode==='aum' || mode==='auto' || mode==='aum-expand'){
    let aum=extractAumPdf(text);
    if(aum){
      if(mode==='aum-expand' || opts.expandAum) aum=expandAumToAccountRows(aum);
      return aum;
    }
    if(mode==='aum' || mode==='aum-expand') return null;
  }

  // 1) Wzorzec tabeli PPE/US z PDF (ciąg ze spacjami + TERM WPL / KOD US)
  const ppe=extractPpeTable(text);
  if(ppe && (!preferCols || preferCols===9)) return ppe;

  // 2) Zwykły podział linii
  let rows=parseText(text, mode==='auto'?'words':mode);
  if(!rows) return null;

  // 3) Ciąg bez podziału wierszy → reflow
  if(rows.length===1 && rows[0].length>=(preferCols||9)){
    const w=preferCols||9;
    // jeśli zaczyna się od nagłówków LP POD… OKR ROK TERM WPL…
    const flat=rows[0];
    const joined=flat.join(' ');
    if(/LP/i.test(joined) && /POD/i.test(joined) && /KWOTA/i.test(joined)){
      const ppe2=extractPpeTable(joined);
      if(ppe2) return ppe2;
      // zdejmij znane nagłówki wielowyrazowe z początku
      let rest=joined.replace(/^\s*LP\s+POD\s+OKR\s+ROK\s+TERM\s+WPL\s+KOD\s+US\s+KWOTA\s+ODSETKI\s+SUMA\s+/i,'');
      const ppe3=extractPpeTable(rest);
      if(ppe3) return ppe3;
      const tokens=rest.trim().split(/\s+/).filter(Boolean);
      const body=reflowTokens(tokens, w);
      if(body) return [PPE_HEADERS.slice(), ...body];
    }
    const body=reflowTokens(flat, w);
    if(body) rows=body;
  }

  rows=fixMatrixHeaders(rows, preferCols||0);
  return rows;
}

function splitLine(line, mode){
  const s=String(line).replace(/\u00a0/g,' ').replace(/[\u2000-\u200b\u202f\u205f\u3000]/g,' ');
  if(mode==='tab') return s.split('\t');
  if(mode==='semi') return s.split(';');
  if(mode==='pipe') return s.split('|');
  if(mode==='comma') return s.split(',');
  if(mode==='spaces') return s.trim().split(/\s{2,}|\t+/).filter(x=>x!=='');
  if(mode==='words') return s.trim().split(/\s+/).filter(x=>x!==''); // każda spacja = nowa kolumna (PDF z Acrobat)
  if(s.includes('\t')) return s.split('\t');
  if((s.match(/;/g)||[]).length>=2) return s.split(';');
  if((s.match(/\|/g)||[]).length>=2) return s.split('|');
  if(/\s{2,}/.test(s)) return s.trim().split(/\s{2,}|\t+/).filter(x=>x!=='');
  if(/\s/.test(s.trim())) return s.trim().split(/\s+/).filter(x=>x!=='');
  return [s.trim()];
}
function scoreMatrix(rows){
  if(!rows||!rows.length) return -1;
  const widths=rows.map(r=>r.length);
  const maxW=Math.max(...widths);
  if(maxW<2) return 0;
  const consistent=widths.filter(w=>Math.abs(w-maxW)<=1).length/rows.length;
  // preferuj równy układ wielu kolumn (np. 9 z PDF), karaj chaos
  return maxW*consistent*(consistent>=0.55?1:0.15);
}
function parseText(text, mode){
  const lines=String(text||'').replace(/\r\n/g,'\n').replace(/\r/g,'\n').split('\n')
    .map(l=>l.replace(/\u00a0/g,' ').replace(/[\u2000-\u200b\u202f\u205f\u3000]/g,' '))
    .filter(l=>l.trim()!=='');
  if(!lines.length) return null;
  const m=mode||'auto';

  // PDF PPE/US: ciąg ze spacjami + nagłówki TERM WPL / KOD US
  if(m==='auto'||m==='words'||m==='ppe'){
    const ppe=extractPpeTable(lines.join(' '));
    if(ppe) return ppe;
  }
  if(m!=='auto') return lines.map(l=>splitLine(l,m).map(norm));

  // 1) Excel / TSV
  if(lines.some(l=>l.includes('\t'))){
    const rows=lines.map(l=>splitLine(l,'tab').map(norm));
    if(scoreMatrix(rows)>0) return rows;
  }
  // 2) kolumny rozdzielone 2+ spacjami
  const spaced=lines.map(l=>splitLine(l,'spaces').map(norm));
  if(scoreMatrix(spaced)>0) return spaced;
  // 3) inne separatory albo PDF z pojedynczymi spacjami
  let best=null, bestScore=-1;
  ['semi','pipe','comma','words'].forEach(mm=>{
    const rows=lines.map(l=>splitLine(l,mm).map(norm));
    const sc=scoreMatrix(rows);
    if(sc>bestScore){ bestScore=sc; best=rows; }
  });
  if(best && bestScore>0) return fixMatrixHeaders(best, 0);
  return lines.map(l=>[norm(l)]);
}
function matrixPreview(rows){
  if(!rows||!rows.length) return 'Brak danych';
  const cols=Math.max(...rows.map(r=>r.length));
  const sample=(rows[0]||[]).slice(0,9).join(' | ')+(cols>9?' | …':'');
  return rows.length+' wierszy × '+cols+' kolumn'+(sample?(' · np.: '+sample):'');
}
function looksLikeHeaderRow(row, nextRow){
  if(!row||row.length<2) return false;
  const filled=row.filter(c=>norm(c)!=='');
  if(filled.length<Math.ceil(row.length*0.5)) return false;
  const joined=filled.join(' ').toUpperCase();
  // typowe nagłówki US/PPE
  if(/\bLP\b/.test(joined) && /\bPOD\b/.test(joined) && /\bKWOTA\b/.test(joined)) return true;
  if(PPE_HEADERS.every((h,i)=>norm(row[i]||'').toUpperCase()===h.toUpperCase())) return true;
  const asNumDate=filled.filter(c=>{
    const v=norm(c);
    return toNum(v)!=null || /^\d{1,2}[./-]\d{1,2}[./-]\d{2,4}$/.test(v);
  }).length;
  if(asNumDate/filled.length>=0.5) return false;
  if(nextRow){
    const nf=nextRow.filter(c=>norm(c)!=='');
    const nd=nf.filter(c=>{ const v=norm(c); return toNum(v)!=null || /^\d{1,2}[./-]/.test(v); }).length;
    const alpha=filled.filter(c=>/[A-Za-zĄĆĘŁŃÓŚŹŻąćęłńóśźż]/.test(c) && toNum(c)==null).length;
    if(alpha/filled.length>=0.45 && nf.length && nd/nf.length>=0.35) return true;
  }
  return asNumDate/filled.length<0.35;
}
function build(matrix){
  const m=matrix.map(r=>r.slice(0,MAX)); const w=Math.min(MAX,Math.max(0,...m.map(r=>r.length)));
  const first=m[0]||[]; const header=m.length>1&&looksLikeHeaderRow(first, m[1]);
  let headers,rows; if(header){headers=first.map((h,i)=>h||('Kolumna '+letter(i))); rows=m.slice(1);} else{headers=Array.from({length:w},(_,i)=>'Kolumna '+letter(i)); rows=m;}
  while(headers.length<w) headers.push('Kolumna '+letter(headers.length));
  headers=headers.slice(0,MAX); rows=rows.map(r=>Array.from({length:headers.length},(_,i)=>r[i]||'')); return {headers,rows};
}
function detectNumericCol(sh, ci){let n=0,t=0; for(let i=0;i<Math.min(sh.rows.length,40);i++){const v=norm(sh.rows[i][ci]); if(v==='') continue; t++; if(toNum(v)!=null) n++;} return t>0 && n/t>=0.7;}
function rememberPaste(matrix, label){
  if(!matrix||!matrix.length) return;
  App.pasteHistory.unshift({ts:Date.now(), matrix:matrix.map(r=>r.slice()), label:label||matrixPreview(matrix)});
  if(App.pasteHistory.length>PASTE_HIST_MAX) App.pasteHistory.length=PASTE_HIST_MAX;
}
function loadMatrix(matrix, append){
  const sh=active(); if(!matrix||!matrix.length||!sh) return;
  rememberPaste(matrix, append?'Dopis':'Wklej');
  const p=build(matrix);
  if(!append||!sh.columns.length){
    pushUndo();
    sh.columns=p.headers; sh.rows=p.rows; sh.order=sh.columns.map((_,i)=>i); sh.visible=sh.columns.map(()=>true); sh.widths=sh.columns.map(()=>150);
    sh.sort={i:-1,d:1}; sh.selected.clear(); sh.last=-1; sh.rowColors={}; sh.marks={}; sh.rowStatus={}; sh.colFilters={}; sh.filter=''; sh.colorRules=sh.colorRules||[];
    ensureHidden(sh); sh.hiddenRows=new Set();
    $('filterInput').value='';
  }else{ pushUndo(); const w=Math.max(sh.columns.length,p.headers.length); while(sh.columns.length<w){const i=sh.columns.length; sh.columns.push('Kolumna '+letter(i)); sh.order.push(i); sh.visible.push(true); sh.widths.push(150);} p.rows.forEach(r=>sh.rows.push(Array.from({length:w},(_,i)=>r[i]||''))); }
  applyColorRules(sh);
  let msg='Wklejono '+p.rows.length+' wierszy';
  const meta=extractPpeTable._meta;
  if(meta && meta.maxLp && meta.maxLp>p.rows.length){
    msg+=' · UWAGA: LP sięga '+meta.maxLp+', brakuje ~'+(meta.maxLp-p.rows.length)+' (sprawdź wklejkę)';
  }else if(meta && meta.rows){
    msg+=' · LP do '+(meta.maxLp||meta.rows);
  }
  if(meta && meta.pdfSuma && meta.pdfSuma.length){
    sh.pdfSuma=meta.pdfSuma.slice(0,3);
    msg+=' · stopka Suma: z PDF';
  }
  extractPpeTable._meta=null;
  if(isRegistrySheet(sh)){
    const fin=finalizeRegistryAfterPaste(sh);
    if(fin.added.length) msg+=' · doklejono: '+fin.added.join(', ');
    else msg+=' · baza Zobowiązani (A=NIP, B=PESEL + systemy)';
    setRibbonTab('rejestr', {silent:true});
  }else{
    if(App.workMode==='linked' && sh.name!==PARK_SHEET && sh.name!=='Archiwum'){
      const addedSys=finalizeLinkedListAfterPaste(sh);
      if(addedSys.length) msg+=' · tryb Z BAZĄ → doklejono: '+addedSys.join(', ');
    }
    setRibbonTab('edycja');
  }
  let fitted=false;
  const allowWrap=(p.rows.length<VIRT_THRESHOLD);
  if(App.activeSchema && !isRegistrySheet(sh)){
    const ok=confirm('Zastosować schemat „'+App.activeSchema+'”?');
    if(ok) applySchemaByName(App.activeSchema,false);
    else { fitColumnWidths(sh,{wrap:allowWrap}); if(!allowWrap) App.wrap=false; fitted=true; render(); }
  }else{
    fitColumnWidths(sh,{wrap:allowWrap}); if(!allowWrap) App.wrap=false; fitted=true; render();
  }
  if(fitted) msg+=' · kolumny dopasowane';
  toast(msg);
  scheduleAutosave();
}

function filterKey(v){
  const s=norm(v);
  if(s==='') return 's:';
  const n=toNum(s);
  if(n!=null) return 'n:'+n;
  return 's:'+s.toLowerCase();
}
function passColFilter(val, f){
  if(!f||f.mode==='any'||!f.mode) return true;
  const v=norm(val);
  if(f.mode==='empty') return v==='';
  if(f.mode==='notempty') return v!=='';
  if(f.mode==='equals') return v.toLowerCase()===String(f.text||'').toLowerCase();
  if(f.mode==='contains') return !f.text || v.toLowerCase().includes(String(f.text).toLowerCase());
  if(f.mode==='not_contains') return !f.text || !v.toLowerCase().includes(String(f.text).toLowerCase());
  if(f.mode==='starts') return !f.text || v.toLowerCase().startsWith(String(f.text).toLowerCase());
  if(f.mode==='range'){
    const num=toNum(v); if(num==null) return false;
    if(f.min!==''&&f.min!=null && num<Number(String(f.min).replace(',','.'))) return false;
    if(f.max!==''&&f.max!=null && num>Number(String(f.max).replace(',','.'))) return false;
    return true;
  }
  if(f.mode==='in_list'){
    if(!f.values||!f.values.length) return false;
    const want=f._keySet||(f._keySet=new Set(f.values.map(filterKey)));
    return want.has(filterKey(val));
  }
  return true;
}
function visCols(sh){return sh.order.filter(i=>sh.visible[i]);}
function filtered(sh){
  ensureHidden(sh);
  const q=sh.filter.trim().toLowerCase();
  return sh.rows.map((row,i)=>{
    if(sh.hiddenRows.has(i)) return -1;
    if(q && !row.some(c=>String(c).toLowerCase().includes(q))) return -1;
    for(const [ci,f] of Object.entries(sh.colFilters||{})){ if(!passColFilter(row[+ci], f)) return -1; }
    return i;
  }).filter(i=>i>=0);
}
function sorted(sh, idxs){
  if(sh.sort.i<0) return idxs.slice(); const c=sh.sort.i,d=sh.sort.d;
  return idxs.slice().sort((a,b)=>{
    const av=sh.rows[a][c], bv=sh.rows[b][c]; const an=toNum(av), bn=toNum(bv);
    let cmp; if(an!=null&&bn!=null) cmp=an-bn; else cmp=String(av).localeCompare(String(bv),'pl',{numeric:true,sensitivity:'base'});
    return cmp*d;
  });
}
function filterLabel(sh, ci, f){
  const name=sh.columns[ci]||('Kol '+ci);
  if(f.mode==='in_list'){
    const n=f.values?f.values.length:0;
    if(n===1) return name+': „'+(f.values[0]===''?'(puste)':f.values[0])+'”';
    return name+': '+n+' wartości';
  }
  if(f.mode==='equals') return name+': = „'+f.text+'”';
  if(f.mode==='contains') return name+': zawiera „'+f.text+'”';
  if(f.mode==='not_contains') return name+': nie zawiera „'+f.text+'”';
  if(f.mode==='starts') return name+': zaczyna „'+f.text+'”';
  if(f.mode==='empty') return name+': puste';
  if(f.mode==='notempty') return name+': niepuste';
  if(f.mode==='range') return name+': '+(f.min!==''&&f.min!=null?f.min:'…')+' – '+(f.max!==''&&f.max!=null?f.max:'…');
  return name;
}
function hasActiveFilter(f){
  if(!f||!f.mode||f.mode==='any') return false;
  if(f.mode==='in_list') return Array.isArray(f.values);
  if(f.mode==='contains'||f.mode==='not_contains'||f.mode==='starts'||f.mode==='equals') return String(f.text||'')!=='';
  if(f.mode==='range') return String(f.min??'')!==''||String(f.max??'')!=='';
  return true;
}

function applyColorRules(sh){
  sh._ruleColors={};
  (sh.colorRules||[]).forEach(rule=>{
    const ci=sh.columns.findIndex(c=>c===rule.column); if(ci<0) return;
    sh.rows.forEach((row,ri)=>{
      if(sh._ruleColors[ri]) return; // first matching rule
      const v=row[ci];
      let ok=false;
      if(rule.op==='contains') ok=norm(v).toLowerCase().includes(String(rule.value||'').toLowerCase());
      else if(rule.op==='empty') ok=norm(v)==='';
      else if(rule.op==='notempty') ok=norm(v)!=='';
      else { const num=toNum(v), thr=Number(String(rule.value).replace(',','.')); if(num==null||isNaN(thr)) ok=false;
        else if(rule.op==='>') ok=num>thr; else if(rule.op==='<') ok=num<thr; else if(rule.op==='>=') ok=num>=thr; else if(rule.op==='<=') ok=num<=thr; else if(rule.op==='=') ok=num===thr; }
      if(ok) sh._ruleColors[ri]=rule.color;
    });
  });
}
function rowColor(sh, ri){return sh.rowColors[ri] || (sh._ruleColors&&sh._ruleColors[ri]) || '';}

function captureSchema(){
