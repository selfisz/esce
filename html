  if(f.mode==='starts') return !f.text || v.toLowerCase().startsWith(String(f.text).toLowerCase());
  if(f.mode==='range'){
    const num=toNum(v); if(num==null) return false;
    if(f.min!==''&&f.min!=null && num<Number(String(f.min).replace(',','.'))) return false;
    if(f.max!==''&&f.max!=null && num>Number(String(f.max).replace(',','.'))) return false;
    return true;
  }
  if(f.mode==='in_list'){
    return f.values && f.values.includes(v);
  }
  return true;
}
function visCols(sh){return sh.order.filter(i=>sh.visible[i]);}
function filtered(sh){
  ensureHidden(sh);
  const q=sh.filter.trim().toLowerCase();
  return sh.rows.map((row,i)=>{
    if(sh.hiddenRows.has(i)) return -1;
    if(q && !row.some(c=>String(c).toLowerCase().includes(q))) return -1;
    for(const [ci,f] of Object.entries(sh.colFilters||{})){ if(!passColFilter(row[+ci], f)) return -1; }
    return i;
  }).filter(i=>i>=0);
}
function sorted(sh, idxs){
  if(sh.sort.i<0) return idxs.slice(); const c=sh.sort.i,d=sh.sort.d;
  return idxs.slice().sort((a,b)=>{
    const av=sh.rows[a][c], bv=sh.rows[b][c]; const an=toNum(av), bn=toNum(bv);
    let cmp; if(an!=null&&bn!=null) cmp=an-bn; else cmp=String(av).localeCompare(String(bv),'pl',{numeric:true,sensitivity:'base'});
    return cmp*d;
  });
}
function filterLabel(sh, ci, f){
  const name=sh.columns[ci]||('Kol '+ci);
  if(f.mode==='in_list') return name+': wybrane ('+(f.values?f.values.length:0)+')';
  if(f.mode==='equals') return name+': = „'+f.text+'”';
  if(f.mode==='contains') return name+': zawiera „'+f.text+'”';
  if(f.mode==='starts') return name+': zaczyna „'+f.text+'”';
  if(f.mode==='empty') return name+': puste';
  if(f.mode==='notempty') return name+': niepuste';
  if(f.mode==='range') return name+': '+(f.min!==''?f.min:'…')+' – '+(f.max!==''?f.max:'…');
  return name;
}
function hasActiveFilter(f){return f&&f.mode&&f.mode!=='any';}

function applyColorRules(sh){
  sh._ruleColors={};
  (sh.colorRules||[]).forEach(rule=>{
    const ci=sh.columns.findIndex(c=>c===rule.column); if(ci<0) return;
    sh.rows.forEach((row,ri)=>{
      if(sh._ruleColors[ri]) return; // first matching rule
      const v=row[ci];
      let ok=false;
      if(rule.op==='contains') ok=norm(v).toLowerCase().includes(String(rule.value||'').toLowerCase());
      else if(rule.op==='empty') ok=norm(v)==='';
      else if(rule.op==='notempty') ok=norm(v)!=='';
      else { const num=toNum(v), thr=Number(String(rule.value).replace(',','.')); if(num==null||isNaN(thr)) ok=false;
        else if(rule.op==='>') ok=num>thr; else if(rule.op==='<') ok=num<thr; else if(rule.op==='>=') ok=num>=thr; else if(rule.op==='<=') ok=num<=thr; else if(rule.op==='=') ok=num===thr; }
      if(ok) sh._ruleColors[ri]=rule.color;
    });
  });
}
function rowColor(sh, ri){return sh.rowColors[ri] || (sh._ruleColors&&sh._ruleColors[ri]) || '';}

function captureSchema(){
  const sh=active();
  return {name:'', order:sh.order.slice(), visible:sh.visible.slice(), widths:sh.widths.slice(), sort:Object.assign({},sh.sort),
    filter:sh.filter, colFilters:JSON.parse(JSON.stringify(sh.colFilters||{})), colorRules:JSON.parse(JSON.stringify(sh.colorRules||[])),
    wrap:App.wrap, center:App.center, theme:App.theme, columns:sh.columns.slice()};
}
function applySchema(schema, push){
  const sh=active(); if(!sh||!schema) return;
  if(push!==false) pushUndo();
  // map by column name when possible
  const nameToIdx={}; sh.columns.forEach((n,i)=>nameToIdx[n]=i);
  if(schema.columns && schema.columns.length){
    const newOrder=[]; schema.order.forEach(oldCi=>{
      const name=schema.columns[oldCi]; const idx=nameToIdx[name]; if(idx!=null && !newOrder.includes(idx)) newOrder.push(idx);
    });
    sh.columns.forEach((_,i)=>{if(!newOrder.includes(i)) newOrder.push(i);});
    sh.order=newOrder;
    sh.visible=sh.columns.map((_,i)=>{
      const name=sh.columns[i]; const oldCi=schema.columns.indexOf(name);
      return oldCi>=0 ? !!schema.visible[oldCi] : true;
    });
    sh.widths=sh.columns.map((_,i)=>{
      const name=sh.columns[i]; const oldCi=schema.columns.indexOf(name);
      return oldCi>=0 ? (schema.widths[oldCi]||150) : 150;
    });
    // remap filters/sort/rules by name
    const mappedFilters={};
    Object.entries(schema.colFilters||{}).forEach(([oldCi,f])=>{
      const name=schema.columns[+oldCi]; const idx=nameToIdx[name]; if(idx!=null) mappedFilters[idx]=f;
    });
    sh.colFilters=mappedFilters;
    if(schema.sort && schema.sort.i>=0){ const sn=schema.columns[schema.sort.i]; sh.sort={i:nameToIdx[sn]??-1, d:schema.sort.d||1}; }
    else sh.sort={i:-1,d:1};
    sh.colorRules=(schema.colorRules||[]).map(r=>Object.assign({},r));
  }else{
    sh.order=schema.order.slice(); sh.visible=schema.visible.slice(); sh.widths=schema.widths.slice();
    sh.sort=Object.assign({},schema.sort); sh.colFilters=JSON.parse(JSON.stringify(schema.colFilters||{}));
    sh.colorRules=JSON.parse(JSON.stringify(schema.colorRules||[]));
  }
  sh.filter=schema.filter||''; $('filterInput').value=sh.filter;
  App.wrap=!!schema.wrap; App.center=!!schema.center; if(schema.theme) App.theme=schema.theme;
  App.activeSchema=schema.name||App.activeSchema;
  applyColorRules(sh); render(); toast('Zastosowano schemat'+(schema.name?': '+schema.name:''));
}
function applySchemaByName(name, push){const s=App.schemas.find(x=>x.name===name); if(s) applySchema(s, push);}

