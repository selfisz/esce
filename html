.side-h{padding:12px 12px 8px;font-weight:700;font-size:.9rem}.side-a{display:flex;gap:6px;padding:0 10px 8px}.side-a .btn{flex:1;color:var(--text);background:var(--panel2);border-color:var(--line)}
.cols{overflow:auto;padding:6px 8px;flex:1}.col{display:flex;gap:8px;align-items:center;padding:6px 8px;border-radius:8px}.col:hover{background:var(--panel2)}
.col label{display:flex;gap:8px;align-items:center;flex:1;min-width:0;cursor:pointer;font-size:.82rem}
.badge{font-family:var(--mono);font-size:.66rem;background:var(--soft);color:var(--accent);padding:2px 6px;border-radius:6px}
.foot{padding:10px;border-top:1px solid var(--line);font-size:.7rem;color:var(--muted);line-height:1.4}
