.sheetbar{display:flex;align-items:stretch;gap:0;padding:0 8px;background:linear-gradient(180deg,var(--panel2),color-mix(in srgb,var(--panel2) 70%,var(--line)));border-top:1px solid var(--line);min-height:38px;overflow:auto}
.sheet{appearance:none;border:1px solid transparent;border-bottom:0;background:transparent;color:var(--muted);padding:8px 14px;font:inherit;font-size:.8rem;cursor:grab;border-radius:8px 8px 0 0;margin-top:6px;white-space:nowrap}
