}
function clearSelRange(){ App.selRange=null; }
function inSelRange(ri,ci){
  const s=App.selRange; if(!s) return false;
  return ri>=s.r0 && ri<=s.r1 && ci>=s.c0 && ci<=s.c1;
}
function focusCell(ri,ci,extend){
  const sh=active(); if(!sh||ri<0||ci<0||ri>=sh.rows.length||ci>=sh.columns.length) return;
  if(App.editing) endEdit(true);
  if(extend && App.anchorCell){
    setSelRange(App.anchorCell.r, App.anchorCell.c, ri, ci);
  }else{
    App.anchorCell={r:ri,c:ci};
    setSelRange(ri,ci,ri,ci);
  }
  setActiveCell(sh,ri,ci);
  sh.last=ri;
}
function moveActive(dr,dc,extend){
  const sh=active(); if(!sh||!App.activeCell) return;
  const cols=visCols(sh); if(!cols.length) return;
  const idxs=sorted(sh, filtered(sh)); if(!idxs.length) return;
  let vi=idxs.indexOf(App.activeCell.r); if(vi<0) vi=0;
  let vci=cols.indexOf(App.activeCell.c); if(vci<0) vci=0;
  vi=Math.max(0, Math.min(idxs.length-1, vi+dr));
  vci=Math.max(0, Math.min(cols.length-1, vci+dc));
  focusCell(idxs[vi], cols[vci], extend);
  renderGrid();
  scrollActiveIntoView();
}
function scrollActiveIntoView(){
  const el=document.querySelector('td.cell-active');
  if(el) el.scrollIntoView({block:'nearest', inline:'nearest'});
}
function rangeTSV(sh){
  const s=App.selRange; if(!s) return '';
  const lines=[];
  for(let r=s.r0;r<=s.r1;r++){
    const row=[];
    for(let c=s.c0;c<=s.c1;c++) row.push(sh.rows[r]?.[c]??'');
    lines.push(row.join('\t'));
  }
  return lines.join('\r\n');
}
function clearRangeCells(){
  const sh=active(); const s=App.selRange; if(!sh||!s) return;
  pushUndo();
  for(let r=s.r0;r<=s.r1;r++){
    for(let c=s.c0;c<=s.c1;c++){
      if(r<sh.rows.length && c<sh.columns.length) sh.rows[r][c]='';
    }
  }
  applyColorRules(sh);
  if(App.activeCell) setActiveCell(sh, App.activeCell.r, App.activeCell.c);
  renderGrid();
}
function endEdit(commit){
  if(!App.editing) return;
  const sh=active();
  const {r,c,original}=App.editing;
  const inp=document.querySelector('input.cell-editor');
  const v=inp?inp.value.replace(/\n/g,' ').replace(/\u00a0/g,' '):(commit?original:original);
  App.editing=null;
  if(commit && sh && r>=0 && c>=0 && r<sh.rows.length && c<sh.columns.length){
    if(String(sh.rows[r][c]??'')!==v){
      pushUndo();
      sh.rows[r][c]=v;
      applyColorRules(sh);
    }
    setActiveCell(sh,r,c);
  }else if(sh && App.activeCell){
    setActiveCell(sh, App.activeCell.r, App.activeCell.c);
  }
  renderGrid();
}
function beginEdit(ri,ci,seed){
  const sh=active(); if(!sh||ri<0||ci<0) return;
  if(App.editing && (App.editing.r!==ri||App.editing.c!==ci)) endEdit(true);
  focusCell(ri,ci,false);
  App.editing={r:ri,c:ci, original:String(sh.rows[ri][ci]??''), seed:seed==null?null:String(seed)};
  renderGrid();
  const inp=document.querySelector('input.cell-editor');
  if(inp){
    if(seed!=null){ inp.value=String(seed); inp.setSelectionRange(inp.value.length, inp.value.length); }
    else { inp.select(); }
    inp.focus();
  }
}
function commitActiveCell(){
  const sh=active(); if(!sh||!App.activeCell) return;
  if(App.editing){ endEdit(true); return; }
  const {r,c}=App.activeCell;
  if(r<0||c<0||r>=sh.rows.length||c>=sh.columns.length) return;
  const v=$('cellValue').innerText.replace(/\n/g,' ').replace(/\u00a0/g,' ');
  if(String(sh.rows[r][c]??'')===v) return;
  pushUndo();
  sh.rows[r][c]=v;
  applyColorRules(sh);
  renderGrid();
  setActiveCell(sh,r,c);
}
function isGridTypingTarget(el){
  if(!el) return false;
  if(el.closest && el.closest('.cell-editor')) return true;
  if(el.id==='cellValue' || el.closest?.('#cellValue')) return true;
  if(el.matches?.('input:not([type="checkbox"]), textarea, select')) return true;
  if(el.isContentEditable) return true;
  return false;
}
function buildRowTr(sh, ri, displayIdx, cols, idxs){
  const tr=document.createElement('tr'); if(sh.selected.has(ri)) tr.classList.add('selected');
  const rc=rowColor(sh,ri); if(rc && !App.plain) tr.classList.add('rc-'+rc);
  ensureRowStatus(sh);
  const st=sh.rowStatus[ri]||'';
  let stBadge='';
  if(st) {
    const stObj = App.statuses.find(s=>s.id===st);
    const color = stObj ? stObj.color : 'gray';
    const label = stObj ? stObj.label : st;
    tr.classList.add('st-c-'+color);
    stBadge = `<span class="badge-st c-${color}" title="${label}">${label.slice(0,1)}</span>`;
  }
  const ctd=document.createElement('td'); ctd.className='corner';
  ctd.innerHTML=`<div class="th-inner" style="justify-content:center;gap:4px"><input type="checkbox" ${sh.selected.has(ri)?'checked':''}><span title="Nr w widoku (po sortowaniu)">${displayIdx+1}</span>${stBadge}</div>`; tr.append(ctd);

  cols.forEach(ci=>{
    const td=document.createElement('td');
    const val=sh.rows[ri][ci]??'';
    const editing=App.editing && App.editing.r===ri && App.editing.c===ci;
    if(App.activeCell&&App.activeCell.r===ri&&App.activeCell.c===ci) td.classList.add('cell-active');
    if(inSelRange(ri,ci) && !(App.activeCell&&App.activeCell.r===ri&&App.activeCell.c===ci)) td.classList.add('cell-range');
    if(editing){
      td.classList.add('cell-editing');
      const inp=document.createElement('input');
      inp.type='text'; inp.className='cell-editor';
      inp.value=App.editing.seed!=null?App.editing.seed:String(val);
      inp.onmousedown=e=>e.stopPropagation();
      inp.onclick=e=>e.stopPropagation();
      inp.onkeydown=e=>{
        if(e.key==='Enter'){ e.preventDefault(); endEdit(true); moveActive(1,0,false); }
        else if(e.key==='Tab'){ e.preventDefault(); endEdit(true); moveActive(0, e.shiftKey?-1:1, false); }
        else if(e.key==='Escape'){ e.preventDefault(); endEdit(false); }
        e.stopPropagation();
      };
      inp.onblur=()=>{ if(App.editing&&App.editing.r===ri&&App.editing.c===ci) endEdit(true); };
      inp.oninput=()=>{ $('cellValue').textContent=inp.value; };
      td.append(inp);
    }else{
      const cell=document.createElement('div'); cell.className='cell'; cell.textContent=val; cell.title=val;
      if(sh.marks[ri]==='dup'&&sh.activeCol===ci) cell.classList.add('mark-dup');
      if(sh.marks[ri]==='empty'&&sh.activeCol===ci&&norm(val)==='') cell.classList.add('mark-empty');
      cell.onmousedown=e=>{
        if(e.button!==0) return;
        e.preventDefault(); e.stopPropagation();
        if(App.editing) endEdit(true);
        App.selecting=true;
        focusCell(ri,ci, e.shiftKey);
        renderGrid();
        updateStatus(sh,idxs);
      };
      cell.onmouseenter=()=>{
        if(!App.selecting || !App.anchorCell) return;
        setSelRange(App.anchorCell.r, App.anchorCell.c, ri, ci);
        setActiveCell(sh,ri,ci);
        renderGrid();
      };
      cell.ondblclick=e=>{ e.preventDefault(); e.stopPropagation(); beginEdit(ri,ci); };
      cell.oncontextmenu=e=>openRowContextMenu(e, ri);
      td.append(cell);
    }
    tr.append(td);
  });
  tr.onclick=e=>{if(e.target.closest('.cell')||e.target.closest('.cell-editor')||e.target.matches('input[type=checkbox]'))return; selectRow(sh,ri,e);};
  tr.oncontextmenu=e=>{ if(e.target.closest('input')) return; openRowContextMenu(e, ri); };
  ctd.querySelector('input').onclick=e=>{e.stopPropagation(); if(e.target.checked) sh.selected.add(ri); else sh.selected.delete(ri); sh.last=ri; renderGrid();};
  ctd.oncontextmenu=e=>openRowContextMenu(e, ri);
  return tr;
}

function openSheetContextMenu(e, sh){
  e.preventDefault();
  e.stopPropagation();
  const ctx=$('ctxMenu');
  ctx.innerHTML='';
  ctx.className='ctx open';
  
  const isReg=isRegistrySheet(sh);
  const isPark=sh.name===PARK_SHEET;
  const isArch=sh.name==='Archiwum';
  const isProtected=isReg||isPark||isArch;
  
  const addBtn=(label, action, danger)=>{
    const btn=document.createElement('button');
    btn.textContent=label;
    if(danger) btn.style.color='var(--danger)';
    btn.onclick=()=>{ ctx.classList.remove('open'); action(); };
    ctx.append(btn);
  };
  
  addBtn('Zmień nazwę', ()=>{ sh._renaming=true; renderSheetBar(); });
  
  if(!isProtected){
    const sep=document.createElement('div'); sep.className='sep'; ctx.append(sep);
    addBtn('Wyczyść kartę', ()=>{
      if(!confirm('Wyczyścić kartę „'+sh.name+'"?')) return;
      pushUndo();
      Object.assign(sh,{columns:[],rows:[],order:[],visible:[],widths:[],sort:{i:-1,d:1},filter:'',colFilters:{},rowColors:{},marks:{},rowStatus:{},hiddenRows:new Set()});
      sh.selected.clear();
      render();
      toast('Wyczyszczono kartę');
    });
    addBtn('Usuń kartę', ()=>{
      if(App.sheets.length<=1){ toast('Musi zostać przynajmniej jedna karta'); return; }
      if(!confirm('Usunąć kartę „'+sh.name+'"?')) return;
      pushUndo();
      const idx=App.sheets.findIndex(x=>x.id===sh.id);
      App.sheets.splice(idx,1);
      if(App.activeId===sh.id) App.activeId=App.sheets[0].id;
      render();
      toast('Usunięto kartę');
    }, true);
  }else{
    const sep=document.createElement('div'); sep.className='sep'; ctx.append(sep);
    const info=document.createElement('div');
    info.style.cssText='padding:8px 10px;font-size:.75rem;color:var(--muted)';
    info.textContent=isReg?'Baza Zobowiązanych — nie można usunąć':isPark?'Parking — nie można usunąć':'Archiwum — nie można usunąć';
    ctx.append(info);
  }
  
  ctx.style.left=Math.min(e.clientX, window.innerWidth-220)+'px';
  ctx.style.top=Math.min(e.clientY, window.innerHeight-200)+'px';
}
function renderSheetBar(){
  const bar=$('sheetbar'); bar.innerHTML='';
  App.sheets.forEach(sh=>{
    // W trybie doraźnym ukryj kartę Zobowiązani
    if(App.workMode==='adhoc' && isRegistrySheet(sh)) return;
    
    const b=document.createElement('button'); b.type='button';
    let cls='sheet'+(sh.id===App.activeId?' active':'');
    if(isRegistrySheet(sh)) cls+=' sheet-base';
    if(sh.name===PARK_SHEET) cls+=' sheet-park';
    b.className=cls; b.draggable=true;
    if(isRegistrySheet(sh)) b.title='BAZA ludzi — wklejasz zobowiązanych (PESEL)';
    else if(sh.name===PARK_SHEET) b.title='Odłożone sprawy';
    else b.title='Lista do obróbki — wklejasz raporty. PPM = opcje.';
    if(sh._renaming){ const inp=document.createElement('input'); inp.value=sh.name; inp.onclick=e=>e.stopPropagation();
      const done=()=>{sh.name=inp.value.trim()||sh.name; sh._renaming=false; render();};
      inp.onkeydown=e=>{if(e.key==='Enter')done(); if(e.key==='Escape'){sh._renaming=false; renderSheetBar();}}; inp.onblur=done; b.append(inp); setTimeout(()=>inp.select(),0);
    } else {
      b.textContent=isRegistrySheet(sh)?('★ '+sh.name):sh.name;
      b.onclick=()=>{
        App.activeId=sh.id; App.activeCell=null; $('cellRef').textContent='—'; $('cellValue').textContent='';
        if(isRegistrySheet(sh)) setRibbonTab('rejestr',{silent:true});
        else if(App.ribbonTab==='rejestr') setRibbonTab('dane',{silent:true});
        render();
      };
      b.ondblclick=e=>{e.preventDefault(); sh._renaming=true; renderSheetBar();};
      b.oncontextmenu=e=>openSheetContextMenu(e, sh);
    }
    b.ondragstart=e=>{App.dragSheet=sh.id; b.classList.add('dragging'); e.dataTransfer.effectAllowed='move';};
    b.ondragend=()=>{App.dragSheet=null; document.querySelectorAll('.sheet').forEach(x=>x.classList.remove('dragging','drag-over'));};
    b.ondragover=e=>{e.preventDefault(); b.classList.add('drag-over');}; b.ondragleave=()=>b.classList.remove('drag-over');
    b.ondrop=e=>{e.preventDefault(); if(!App.dragSheet||App.dragSheet===sh.id)return; const from=App.sheets.findIndex(x=>x.id===App.dragSheet), to=App.sheets.findIndex(x=>x.id===sh.id); const m=App.sheets.splice(from,1)[0]; App.sheets.splice(to,0,m); renderSheetBar(); toast('Zmieniono kolejność kart');};
    bar.append(b);
  });
  const add=document.createElement('button'); add.type='button'; add.className='sheet-add'; add.textContent='＋'; add.onclick=()=>{const s=newSheet('Robocza '+App.sheets.length); App.sheets.push(s); App.activeId=s.id; render();}; bar.append(add);
}

function addColumn(refCi, before){
  const sh=active(); if(!sh) return;
  if(sh.columns.length>=MAX){ toast('Limit '+MAX+' kolumn (A–Z)'); return; }
  const def='Kolumna '+letter(sh.columns.length);
  const name=prompt('Nazwa nowej kolumny:', def);
  if(name===null) return;
  pushUndo();
  const ci=sh.columns.length;
  sh.columns.push(name.trim()||def);
  sh.visible.push(true);
  sh.widths.push(140);
  const pos=refCi==null||refCi<0?-1:sh.order.indexOf(refCi);
  if(pos<0) sh.order.push(ci);
  else if(before) sh.order.splice(pos, 0, ci);
  else sh.order.splice(pos+1, 0, ci);
  sh.rows.forEach(r=>{ while(r.length<sh.columns.length) r.push(''); });
  if(!sh.rows.length) sh.rows.push(Array.from({length:sh.columns.length},()=>''));
  applyColorRules(sh); render();
  toast(before?'Wstawiono kolumnę przed':'Dodano kolumnę „'+sh.columns[ci]+'”');
}
function addRow(atRi, before){
  const sh=active(); if(!sh) return;
  if(!sh.columns.length){ toast('Najpierw dodaj kolumnę albo wklej dane'); return; }
  if(atRi==null||atRi<0){
    pushUndo();
    sh.rows.push(Array.from({length:sh.columns.length},()=>''));
    render(); toast('Dodano wiersz '+sh.rows.length);
    return;
  }
  insertRowAt(atRi, !!before);
}
function renameColumn(ci){
  const sh=active(); if(!sh||ci<0||ci>=sh.columns.length) return;
  const name=prompt('Nowa nazwa kolumny:', sh.columns[ci]);
  if(name===null) return;
  const n=name.trim(); if(!n){ toast('Nazwa nie może być pusta'); return; }
  pushUndo();
  const old=sh.columns[ci]; sh.columns[ci]=n;
  (sh.colorRules||[]).forEach(r=>{ if(r.column===old) r.column=n; });
  applyColorRules(sh); render(); toast('Nazwa: „'+n+'”');
}
function deleteColumn(ci){
  const sh=active(); if(!sh||ci<0||ci>=sh.columns.length) return;
  if(sh.columns.length<=1){ if(!confirm('To ostatnia kolumna — usunąć ją (i wyczyścić wiersze)?')) return; }
  else if(!confirm('Usunąć kolumnę „'+sh.columns[ci]+'"?')) return;
  pushUndo();
  const name=sh.columns[ci];
  sh.columns.splice(ci,1);
  sh.visible.splice(ci,1);
  sh.widths.splice(ci,1);
  sh.rows.forEach(r=>r.splice(ci,1));
  sh.order=sh.order.filter(i=>i!==ci).map(i=>i>ci?i-1:i);
  if(sh.sort.i===ci) sh.sort={i:-1,d:1}; else if(sh.sort.i>ci) sh.sort.i--;
  const nf={}; Object.entries(sh.colFilters||{}).forEach(([k,f])=>{ const i=+k; if(i===ci) return; nf[i>ci?i-1:i]=f; }); sh.colFilters=nf;
  sh.colorRules=(sh.colorRules||[]).filter(r=>r.column!==name);
  if(sh.activeCol===ci) sh.activeCol=-1; else if(sh.activeCol>ci) sh.activeCol--;
  if(App.activeCell&&App.activeCell.c===ci) App.activeCell=null;
  else if(App.activeCell&&App.activeCell.c>ci) App.activeCell.c--;
  if(!sh.columns.length){ sh.rows=[]; sh.order=[]; sh.visible=[]; sh.widths=[]; }
  applyColorRules(sh); render(); toast('Usunięto kolumnę');
}
function renderSidebar(sh){
  const box=$('columnList'); box.innerHTML='';
  if(!sh.columns.length){box.innerHTML='<div style="padding:10px;color:var(--muted);font-size:.8rem">Brak kolumn. Dodaj lub wklej dane.</div>'; return;}
  sh.order.forEach((ci,pos)=>{
    const item=document.createElement('div'); item.className='col';
    const lab=document.createElement('label');
    const cb=document.createElement('input'); cb.type='checkbox'; cb.checked=sh.visible[ci]; cb.onchange=()=>{pushUndo(); sh.visible[ci]=cb.checked; renderGrid(); renderChips();};
    const badge=document.createElement('span'); badge.className='badge'; badge.textContent=letter(pos);
    const name=document.createElement('span'); name.textContent=sh.columns[ci]; name.title='Dwuklik = zmień nazwę'; name.style.cssText='overflow:hidden;text-overflow:ellipsis;white-space:nowrap;cursor:text';
    name.ondblclick=e=>{e.preventDefault(); e.stopPropagation(); renameColumn(ci);};
    lab.append(cb,badge,name);
    const acts=document.createElement('div'); acts.className='col-actions';
    const btnIns=document.createElement('button'); btnIns.type='button'; btnIns.textContent='＋'; btnIns.title='Dodaj kolumnę obok'; btnIns.onclick=e=>{e.preventDefault(); e.stopPropagation(); addColumn(ci);};
    const btnDel=document.createElement('button'); btnDel.type='button'; btnDel.className='danger'; btnDel.textContent='×'; btnDel.title='Usuń kolumnę'; btnDel.onclick=e=>{e.preventDefault(); e.stopPropagation(); deleteColumn(ci);};
    acts.append(btnIns, btnDel);
    item.append(lab, acts); box.append(item);
  });
}

function openColFilter(ci, anchor){
  App.filterCol=ci; const sh=active(); const f=Object.assign(emptyFilter(), sh.colFilters[ci]||{});
  const pop=$('colFilterPopup');

  // Unikalne wartości z normalizacją klucza (liczby 1 234,5 ≡ 1234.5; case-insensitive)
  const byKey=new Map();
  sh.rows.forEach(r=>{
    const display=norm(r[ci]);
    const key=filterKey(r[ci]);
    if(!byKey.has(key)) byKey.set(key, display);
  });
  const uniqueVals=[...byKey.values()].sort((a,b)=>{
    if(a===''&&b!=='') return -1; if(b===''&&a!=='') return 1;
    const an=toNum(a), bn=toNum(b);
    if(an!=null&&bn!=null) return an-bn;
    return a.localeCompare(b,'pl',{numeric:true,sensitivity:'base'});
  });
  const uniqueKeys=new Set(uniqueVals.map(filterKey));

  const selectedVals=new Set();
  if(f.mode==='in_list' && Array.isArray(f.values)){
    const want=new Set(f.values.map(filterKey));
    uniqueVals.forEach(v=>{ if(want.has(filterKey(v))) selectedVals.add(v); });
  }else if(!f.mode || f.mode==='any' || !hasActiveFilter(f)){
    uniqueVals.forEach(v=>selectedVals.add(v));
  }else{
    // warunek tekst/liczba/puste — lista startuje odznaczona wizualnie, warunek w polach
    uniqueVals.forEach(v=>selectedVals.add(v));
  }

  pop.innerHTML=`<div style="font-weight:700;margin-bottom:8px;font-size:.85rem">${String(sh.columns[ci]).replace(/</g,'&lt;')}</div>
    <div class="row"><input id="cfSearchList" placeholder="Szukaj na liście…" autocomplete="off"></div>
    <div class="cf-links">
      <a href="#" id="cfSelVisible">Zaznacz widoczne</a>
      <a href="#" id="cfSelNoneVisible">Odznacz widoczne</a>
      <a href="#" id="cfSelAll">Wszystkie</a>
      <a href="#" id="cfSelNone">Żadne</a>
    </div>
    <div class="cf-box" id="cfCheckboxes"></div>
    <div class="cf-sep"></div>
    <div class="cf-sub">Tekst</div>
    <div class="row"><input id="cfText" placeholder="np. 1540…" value=""></div>
    <label class="chk" style="display:flex;gap:8px;align-items:center;font-size:.78rem;margin:0 0 8px"><input type="checkbox" id="cfNotContains"> Nie zawiera (np. bez rachunku 1540)</label>
    <div class="cf-sub">Liczba</div>
    <div class="row"><div style="display:flex;gap:6px"><input id="cfMin" placeholder="Od"><input id="cfMax" placeholder="Do"></div></div>
    <div class="cf-links" style="margin-top:8px">
      <a href="#" id="cfEmpty">Tylko puste</a>
      <a href="#" id="cfNotEmpty">Tylko niepuste</a>
    </div>
    <div class="actions" style="margin-top:12px">
      <button class="btn light sm" id="cfClear" type="button">Wyczyść</button>
      <button class="btn primary sm" id="cfApply" type="button" style="color:#fff">OK</button>
    </div>`;

  pop.querySelector('#cfText').value=(f.mode==='contains'||f.mode==='not_contains'||f.mode==='starts'||f.mode==='equals')?(f.text||''):'';
  pop.querySelector('#cfNotContains').checked=(f.mode==='not_contains');
  pop.querySelector('#cfMin').value=f.mode==='range'?(f.min||''):'';
  pop.querySelector('#cfMax').value=f.mode==='range'?(f.max||''):'';

  const cbBox=pop.querySelector('#cfCheckboxes');
  let visibleVals=[];
  const renderList=(search)=>{
    const q=(search||'').toLowerCase();
    visibleVals=uniqueVals.filter(v=>{
      if(!q) return true;
      if(v==='') return '(puste)'.includes(q) || q==='';
      return v.toLowerCase().includes(q);
    });
    cbBox.innerHTML='';
    visibleVals.forEach(v=>{
      const lbl=document.createElement('label');
      lbl.style.cssText='display:flex;gap:6px;align-items:center;cursor:pointer;padding:2px 2px';
      const cb=document.createElement('input'); cb.type='checkbox'; cb.className='cf-cb';
      cb.checked=selectedVals.has(v);
      cb.onchange=()=>{ if(cb.checked) selectedVals.add(v); else selectedVals.delete(v); };
      const sp=document.createElement('span');
      if(v==='') sp.innerHTML='<em style="opacity:.55">(puste)</em>'; else sp.textContent=v;
      lbl.append(cb, sp); cbBox.append(lbl);
    });
    if(!visibleVals.length) cbBox.innerHTML='<div style="color:var(--muted);padding:6px">Brak na liście</div>';
  };
  renderList();

  pop.querySelector('#cfSearchList').oninput=e=>renderList(e.target.value);
  pop.querySelector('#cfSelVisible').onclick=e=>{ e.preventDefault(); visibleVals.forEach(v=>selectedVals.add(v)); renderList(pop.querySelector('#cfSearchList').value); };
  pop.querySelector('#cfSelNoneVisible').onclick=e=>{ e.preventDefault(); visibleVals.forEach(v=>selectedVals.delete(v)); renderList(pop.querySelector('#cfSearchList').value); };
  pop.querySelector('#cfSelAll').onclick=e=>{ e.preventDefault(); uniqueVals.forEach(v=>selectedVals.add(v)); renderList(pop.querySelector('#cfSearchList').value); };
  pop.querySelector('#cfSelNone').onclick=e=>{ e.preventDefault(); selectedVals.clear(); renderList(pop.querySelector('#cfSearchList').value); };

  const close=()=>{ pop.classList.add('hidden'); };
  const applyFilter=()=>{
    pushUndo();
    const text=pop.querySelector('#cfText').value.trim();
    const min=pop.querySelector('#cfMin').value.trim();
    const max=pop.querySelector('#cfMax').value.trim();
    if(text){
      const not=!!pop.querySelector('#cfNotContains').checked;
      sh.colFilters[ci]={mode:not?'not_contains':'contains', text, min:'', max:''};
    }else if(min!==''||max!==''){
      sh.colFilters[ci]={mode:'range', text:'', min, max};
    }else{
      // lista wartości
      const selectedKeys=new Set([...selectedVals].map(filterKey));
      const allOn=[...uniqueKeys].every(k=>selectedKeys.has(k)) && selectedKeys.size===uniqueKeys.size;
      if(allOn) delete sh.colFilters[ci];
      else sh.colFilters[ci]={mode:'in_list', values:[...selectedVals]};
    }
    close(); render();
  };
  const applyMode=(mode)=>{
    pushUndo();
    sh.colFilters[ci]={mode, text:'', min:'', max:''};
    close(); render();
  };

  pop.querySelector('#cfApply').onclick=applyFilter;
  pop.querySelector('#cfClear').onclick=()=>{ pushUndo(); delete sh.colFilters[ci]; close(); render(); };
  pop.querySelector('#cfEmpty').onclick=e=>{ e.preventDefault(); applyMode('empty'); };
  pop.querySelector('#cfNotEmpty').onclick=e=>{ e.preventDefault(); applyMode('notempty'); };

  const handleEnter=e=>{ if(e.key==='Enter'){ e.preventDefault(); applyFilter(); } };
  pop.querySelector('#cfText').onkeydown=handleEnter;
  pop.querySelector('#cfMin').onkeydown=handleEnter;
  pop.querySelector('#cfMax').onkeydown=handleEnter;
  pop.querySelector('#cfSearchList').onkeydown=handleEnter;

  const r=anchor.getBoundingClientRect();
  pop.classList.remove('hidden');
  pop.style.left=Math.min(window.innerWidth-320, Math.max(8,r.left))+'px';
  pop.style.top=Math.min(window.innerHeight-420, r.bottom+6)+'px';
  setTimeout(()=>pop.querySelector('#cfSearchList').focus(), 40);
}

