.grid.plain tbody tr.rc-yellow td,.grid.plain tbody tr.rc-green td,.grid.plain tbody tr.rc-red td,
.grid.plain tbody tr.rc-blue td,.grid.plain tbody tr.rc-purple td,.grid.plain tbody tr.rc-gray td,
.grid.plain tbody tr.selected.rc-yellow td,.grid.plain tbody tr.selected.rc-green td,.grid.plain tbody tr.selected.rc-red td,
.grid.plain tbody tr.selected.rc-blue td,.grid.plain tbody tr.selected.rc-purple td,.grid.plain tbody tr.selected.rc-gray td{background:transparent!important;box-shadow:none}
.grid.plain tbody tr.selected td{background:#eee!important}
.grid.plain tfoot td{background:#fff;font-weight:700;border-top:2px solid #111}
.grid.plain tfoot td.sum-val{background:#fff;border:1px solid #333}
.empty{position:absolute;inset:0;display:grid;place-items:center;padding:28px;text-align:center;color:var(--muted);background:radial-gradient(600px 240px at 50% 30%,color-mix(in srgb,var(--accent) 12%,transparent),transparent 70%),var(--panel)}
.empty-card{max-width:420px;padding:28px 24px;border:1px dashed color-mix(in srgb,var(--accent) 35%,var(--line));border-radius:18px;background:color-mix(in srgb,var(--panel) 88%,var(--soft))}
