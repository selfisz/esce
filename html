  const sheetOpts=App.sheets.map(s=>`<option value="${s.id}">${s.name.replace(/</g,'&lt;')} (${s.rows.length})</option>`).join('');
  dlg.innerHTML=`<h3>Porównaj karty</h3>
    <p class="hint">Trzy tryby: wspólne (∩), tylko w A (A−B), tylko w B (B−A). Wynik = nowa karta (3) z pełnymi wierszami.</p>
    <div class="row"><label>Tryb</label><select id="cmpMode">
      <option value="intersect">Wspólne PESEL (A ∩ B) → karta 3</option>
      <option value="onlyA">Tylko w A (A − B)</option>
      <option value="onlyB">Tylko w B (B − A)</option>
    </select></div>
    <label class="chk" style="display:flex;gap:8px;align-items:center;font-size:.82rem;margin:0 0 10px"><input type="checkbox" id="cmpVisible" checked> Tylko widoczne wiersze (po filtrach) — np. bez rachunku 1540</label>
    <div class="row"><label>Karta A</label><select id="cmpSheetA">${sheetOpts}</select></div>
    <div class="row"><label>Kolumna klucza w A</label><select id="cmpColA"></select></div>
    <div class="row"><label>Karta B</label><select id="cmpSheetB">${sheetOpts}</select></div>
    <div class="row"><label>Kolumna klucza w B</label><select id="cmpColB"></select></div>
    <div class="hint" id="cmpPreview">Podgląd: —</div>
    <div class="actions">
      <button class="btn light" type="button" id="cmpCancel">Anuluj</button>
      <button class="btn primary" type="button" id="cmpOk" style="color:#fff">Utwórz kartę</button>
    </div>`;
  dlg.classList.remove('hidden'); bd.classList.remove('hidden');

  const fillCols=(selId, sheetId, preferName)=>{
    const sh=App.sheets.find(s=>s.id===sheetId); const sel=dlg.querySelector('#'+selId);
    if(!sh){ sel.innerHTML=''; return; }
    sel.innerHTML=sh.columns.map((c,i)=>`<option value="${i}">${letter(i)} — ${String(c).replace(/</g,'&lt;')}</option>`).join('');
    if(preferName){
      const idx=sh.columns.findIndex(c=>norm(c).toLowerCase()===preferName);
      if(idx>=0) sel.value=String(idx);
      else{
        const soft=sh.columns.findIndex(c=>/pesel/i.test(String(c)));
        if(soft>=0) sel.value=String(soft);
      }
    }
  };
  const sheetA=()=>App.sheets.find(s=>s.id===dlg.querySelector('#cmpSheetA').value);
  const sheetB=()=>App.sheets.find(s=>s.id===dlg.querySelector('#cmpSheetB').value);
  const mode=()=>dlg.querySelector('#cmpMode').value||'intersect';
  const refreshCols=()=>{
    const a=sheetA(), b=sheetB();
    const prefer=a&&a.columns[+dlg.querySelector('#cmpColA').value];
    fillCols('cmpColA', dlg.querySelector('#cmpSheetA').value, prefer?norm(prefer).toLowerCase():null);
    fillCols('cmpColB', dlg.querySelector('#cmpSheetB').value, prefer?norm(prefer).toLowerCase():'pesel');
    const aName=a?norm(a.columns[+dlg.querySelector('#cmpColA').value]).toLowerCase():'';
    if(b && aName){
      const bi=b.columns.findIndex(c=>norm(c).toLowerCase()===aName);
      if(bi>=0) dlg.querySelector('#cmpColB').value=String(bi);
    }
    refreshPreview();
  };
  const rowIdxs=(sh)=>{
    const onlyVis=!!dlg.querySelector('#cmpVisible').checked;
    return onlyVis ? filtered(sh) : sh.rows.map((_,i)=>i);
  };
  const countCompare=(a,b,ca,cb,m)=>{
    const ia=rowIdxs(a), ib=rowIdxs(b);
    const keysA=new Set(), keysB=new Set();
    ia.forEach(i=>{ const k=normKey(a.rows[i][ca]); if(k) keysA.add(k); });
    ib.forEach(i=>{ const k=normKey(b.rows[i][cb]); if(k) keysB.add(k); });
    let hits=0, empty=0;
    if(m==='onlyB'){
      ib.forEach(i=>{
        const k=normKey(b.rows[i][cb]);
        if(!k){ empty++; return; }
        if(!keysA.has(k)) hits++;
      });
    }else{
      ia.forEach(i=>{
        const k=normKey(a.rows[i][ca]);
        if(!k){ empty++; return; }
        if(m==='intersect' ? keysB.has(k) : !keysB.has(k)) hits++;
      });
    }
    return {hits, empty, keysA:keysA.size, keysB:keysB.size, vis:!!dlg.querySelector('#cmpVisible').checked};
  };
  const refreshPreview=()=>{
    const a=sheetA(), b=sheetB();
    const ca=+dlg.querySelector('#cmpColA').value, cb=+dlg.querySelector('#cmpColB').value;
    const el=dlg.querySelector('#cmpPreview');
    const m=mode();
    if(!a||!b||a.id===b.id){ el.textContent='Podgląd: wybierz dwie różne karty'; return; }
    if(ca<0||cb<0||!a.columns.length||!b.columns.length){ el.textContent='Podgląd: brak kolumn'; return; }
    const {hits,empty,vis}=countCompare(a,b,ca,cb,m);
    const label=m==='intersect'?'wspólnych':(m==='onlyA'?'tylko w A':'tylko w B');
    el.textContent='Podgląd: '+hits+' wierszy '+label+(vis?' (po filtrach)':' (całe karty)')+(empty?' · pominięto puste: '+empty:'');
  };

  const act=active();
  if(act) dlg.querySelector('#cmpSheetA').value=act.id;
  const other=App.sheets.find(s=>s.id!==(act&&act.id))||App.sheets[1];
  if(other) dlg.querySelector('#cmpSheetB').value=other.id;
  refreshCols();

  dlg.querySelector('#cmpSheetA').onchange=refreshCols;
  dlg.querySelector('#cmpSheetB').onchange=refreshCols;
  dlg.querySelector('#cmpMode').onchange=refreshPreview;
  dlg.querySelector('#cmpVisible').onchange=refreshPreview;
  dlg.querySelector('#cmpColA').onchange=()=>{
    const a=sheetA(), b=sheetB();
    const aName=a?norm(a.columns[+dlg.querySelector('#cmpColA').value]).toLowerCase():'';
    if(b && aName){
      const bi=b.columns.findIndex(c=>norm(c).toLowerCase()===aName);
      if(bi>=0) dlg.querySelector('#cmpColB').value=String(bi);
    }
    refreshPreview();
  };
  dlg.querySelector('#cmpColB').onchange=refreshPreview;
  dlg.querySelector('#cmpCancel').onclick=()=>{ dlg.classList.add('hidden'); bd.classList.add('hidden'); };
  dlg.querySelector('#cmpOk').onclick=()=>{
    const a=sheetA(), b=sheetB();
    const ca=+dlg.querySelector('#cmpColA').value, cb=+dlg.querySelector('#cmpColB').value;
    const m=mode();
    if(!a||!b||a.id===b.id){ toast('Wybierz dwie różne karty'); return; }
    if(!a.columns.length||!b.columns.length){ toast('Obie karty muszą mieć kolumny'); return; }
    const ia=rowIdxs(a), ib=rowIdxs(b);
    const keysA=new Set(), keysB=new Set();
    ia.forEach(i=>{ const k=normKey(a.rows[i][ca]); if(k) keysA.add(k); });
    ib.forEach(i=>{ const k=normKey(b.rows[i][cb]); if(k) keysB.add(k); });
    let src=a, keyCi=ca, matchIdx=[], srcIdxs=ia, keep=(k)=>keysB.has(k);
    let sheetName='Wspólne', op='∩';
    if(m==='onlyA'){ keep=(k)=>!keysB.has(k); sheetName='Tylko '+a.name; op='−'; }
    if(m==='onlyB'){ src=b; keyCi=cb; srcIdxs=ib; keep=(k)=>!keysA.has(k); sheetName='Tylko '+b.name; op='−'; }
    srcIdxs.forEach(i=>{ const k=normKey(src.rows[i][keyCi]); if(k && keep(k)) matchIdx.push(i); });
    if(!matchIdx.length){ toast('Brak wierszy dla wybranego trybu'); return; }
    const seed={
      columns:src.columns.slice(),
      order:src.order.slice(),
      visible:src.visible.slice(),
      widths:src.widths.slice(),
      rows:matchIdx.map(i=>src.rows[i].slice())
    };
    const ns=newSheet(sheetName.slice(0,40), seed);
    matchIdx.forEach((oldRi,j)=>{
      if(src.rowColors[oldRi]) ns.rowColors[j]=src.rowColors[oldRi];
      if(src.rowStatus&&src.rowStatus[oldRi]) ns.rowStatus[j]=src.rowStatus[oldRi];
    });
    App.sheets.push(ns);
    App.activeId=ns.id;
    dlg.classList.add('hidden'); bd.classList.add('hidden');
    setRibbonTab('edycja');
    render();
    scheduleAutosave();
    toast('Karta „'+ns.name+'”: '+matchIdx.length+' wierszy ('+a.columns[ca]+' '+op+' '+b.columns[cb]+')');
  };
}

