  else if(e.ctrlKey||e.metaKey){if(sh.selected.has(ri)) sh.selected.delete(ri); else sh.selected.add(ri); sh.last=ri;}
  else{sh.selected.clear(); sh.selected.add(ri); sh.last=ri;}
  renderGrid();
}
function updateStatus(sh,idxs){
  ensureHidden(sh);
  $('stSheet').textContent=sh.name; $('stRows').textContent=sh.rows.length; $('stVis').textContent=idxs.length;
  $('stHid').textContent=sh.hiddenRows.size; $('stSel').textContent=sh.selected.size;
