      <div class="menu-wrap"><button class="btn sm" id="btnMoveToExisting" type="button" title="Przenieś do istniejącej karty i usuń z bieżącej">Przenieś ▾</button><div class="menu" id="sheetMoveMenu"></div></div>
      <span class="sep"></span>
      <button class="btn sm" id="btnArchive" type="button" title="Oznacz jako obsłużone i przenieś do Archiwum">Obsłużone → Archiwum</button>
