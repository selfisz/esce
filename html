function buildParkOpis(sh, ri, keyCi){
  const parts=[];
  visCols(sh).forEach(ci=>{
    if(ci===keyCi) return;
    const name=sh.columns[ci];
    if(name==='Stan'||name==='Komplet') return;
    const v=norm(sh.rows[ri][ci]);
    if(!v) return;
    parts.push(name+': '+v);
  });
  if(!parts.length){
    sh.columns.forEach((name,ci)=>{
      if(ci===keyCi||name==='Stan'||name==='Komplet') return;
      const v=norm(sh.rows[ri][ci]);
      if(v) parts.push(name+': '+v);
    });
  }
  const s=parts.join(' · ');
  return s.length>500?s.slice(0,497)+'…':s;
}
function deferSelectedToParking(){
  const sh=active();
  if(!sh||!sh.rows.length){ toast('Brak danych'); return; }
  if(sh.name===PARK_SHEET){ toast('Jesteś już w Na później'); return; }
  if(isRegistrySheet(sh)){ toast('Odkładaj z Listy (JPK itd.), nie z Zobowiązanych'); return; }
  const idxs=sh.selected.size?[...sh.selected].sort((a,b)=>a-b):(App.activeCell?[App.activeCell.r]:[]);
  if(!idxs.length){ toast('Zaznacz wiersze do odłożenia'); return; }
  const keyCi=pickKeyColumnInteractive(sh);
  if(keyCi<0){ toast('Anulowano — potrzebny PESEL'); return; }

  pushUndo();
  const park=ensureParkingSheet(false);
  // kolumny strukturalne ze źródła (po nazwie), z limitem A–Z
  const skip=new Set(['PESEL','Stan','Komplet','Źródło','Opis','Dodano','Status']);
  const extra=[];
  sh.columns.forEach((name,ci)=>{
    if(ci===keyCi) return;
    const n=norm(name); if(!n || skip.has(n)) return;
    if(ensureCol(park, n, 120)>=0) extra.push(n);
  });
  const map={}; park.columns.forEach((n,i)=>map[n]=i);
  const srcTag=(sh.name||'lista')+' '+todayISO();
  let n=0, skipped=0;
  idxs.forEach(ri=>{
    const key=normPesel(sh.rows[ri][keyCi]);
    if(!key){ skipped++; return; }
    const opis=buildParkOpis(sh, ri, keyCi)||'(bez opisu)';
    const fingerprint=extra.map(col=>{
      const sci=sh.columns.indexOf(col);
      return sci>=0?norm(sh.rows[ri][sci]):'';
    }).join('\u0001');
    const dup=park.rows.some(r=>{
      if(normPesel(r[map.PESEL])!==key) return false;
      if(norm(r[map.Status])!==PARK_STATUS_WAIT) return false;
      if(norm(r[map['Źródło']])!==srcTag) return false;
      const fp=extra.map(col=>norm(r[map[col]]||'')).join('\u0001');
      return fp===fingerprint || (norm(r[map.Opis])===opis && !fingerprint);
    });
    if(dup) return;
    const row=Array.from({length:park.columns.length},()=>'');
    row[map.PESEL]=key;
    row[map['Źródło']]=srcTag;
    row[map.Opis]=opis;
    row[map.Dodano]=todayISO();
    row[map.Status]=PARK_STATUS_WAIT;
    extra.forEach(col=>{
      const sci=sh.columns.indexOf(col);
      if(sci>=0 && map[col]!=null) row[map[col]]=norm(sh.rows[ri][sci]);
    });
    park.rows.push(row);
    park.rowColors[park.rows.length-1]='amber';
    n++;
  });
  ensureRegistrySheet(false);
  const reg=getRegistrySheet();
  const rmap=registryColMap(reg);
  const byPesel=registryIndexByPesel(reg);
  idxs.forEach(ri=>{
    const key=normPesel(sh.rows[ri][keyCi]);
    if(!key) return;
    if(byPesel.has(key)) return;
    const row=Array.from({length:reg.columns.length},()=>'');
    row[rmap.PESEL]=key;
    const zci=rmap['Źródła'];
    if(zci!=null) row[zci]=appendSourceTag('', srcTag);
    reg.rows.push(row);
  });
  refreshRegistryDerived(reg);
  render();
  toast(n?('Odłożono '+n+' → Na później'+(extra.length?' · +'+extra.length+' kol.':'')+(skipped?', bez PESEL: '+skipped:'')):'Nic nowego (już było lub brak PESEL)');
}
