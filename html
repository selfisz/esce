async function copySelected(opts){
  opts=opts||{};
  const sh=active(); if(!sh.selected.size){toast('Zaznacz wiersze'); return false;}
  const n=sh.selected.size;
  
  // Inteligentne kopiowanie: jeśli wybrana 1 aktywna komórka - kopiuj tylko jej tekst. 
  // W przeciwnym razie kopiuj całe wiersze.
  let text = '';
  const idxs = [...sh.selected].sort((a,b)=>a-b);
  if(n === 1 && App.activeCell && App.activeCell.r === idxs[0]){
    text = String(sh.rows[App.activeCell.r][App.activeCell.c] ?? '');
  } else {
    text = rowsTSV(sh, idxs);
  }

  try{await navigator.clipboard.writeText(text);}
  catch(_){
    const ta=document.createElement('textarea'); ta.value=text; document.body.appendChild(ta); ta.select();
    document.execCommand('copy'); ta.remove();
  }
  
  const doArch=opts.archive!=null?!!opts.archive:(App.copyMode==='archive');
  if(doArch){
    if(sh.name==='Archiwum'){ toast('Skopiowano '+(n===1&&App.activeCell?'komórkę':'wiersze')+' (jesteś w Archiwum — bez przenoszenia)'); return true; }
    markHandledToArchive({quiet:true, skipEmptyToast:true});
    toast('Skopiowano '+(n===1&&App.activeCell?'komórkę':'wiersze')+' i przeniesiono → Archiwum');
    return true;
  }
  toast('Skopiowano '+(n===1&&App.activeCell?'komórkę':n+' wierszy'));
  return true;
}
