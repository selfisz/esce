  const menu=$('ctxMenu');
  const n=sh.selected.size;
  const expandColors=!!(opts&&opts.expandColors);
  const colors=ROW_PALETTE.map(p=>[p.code,p.label,p.bg]);
  const shown=expandColors?colors:colors.slice(0,4);
  menu.innerHTML='<div class="ctx-h">Wiersz'+(n>1?'e ('+n+')':'')+' — PPM</div>';
