$('cellValue').addEventListener('keydown',e=>{
  if(e.key==='Enter'){ e.preventDefault(); commitActiveCell(); $('cellValue').blur(); }
  if(e.key==='Escape'){ e.preventDefault(); const sh=active(); if(sh&&App.activeCell) setActiveCell(sh,App.activeCell.r,App.activeCell.c); $('cellValue').blur(); }
});
$('cellValue').addEventListener('blur',()=>commitActiveCell());
$('cellValue').addEventListener('focus',()=>{ if($('cellValue').textContent) selectAllText($('cellValue')); });
$('cellValue').onclick=()=>{if($('cellValue').textContent) selectAllText($('cellValue'));};
$('btnClearSheet').onclick=()=>{const sh=active(); if(!sh.rows.length)return; if(!confirm('Wyczyścić kartę?'))return; pushUndo(); Object.assign(sh,{columns:[],rows:[],order:[],visible:[],widths:[],sort:{i:-1,d:1},filter:'',colFilters:{},rowColors:{},marks:{},rowStatus:{},hiddenRows:new Set()}); sh.selected.clear(); $('filterInput').value=''; render();};
$('btnClearFilters').onclick=()=>{pushUndo(); const sh=active(); sh.filter=''; sh.colFilters={}; $('filterInput').value=''; render(); toast('Wyczyszczono filtry');};
