  while(t.length>width){
    let best=-1, bestScore=-1;
    for(let i=0;i<t.length-1;i++){
      const a=t[i], b=t[i+1]; let sc=0;
      if(/^(TERM|KOD|NR|DATA|NR\.?|COL|KOL)/i.test(a)) sc+=6;
      if(/^(WPL|US|PLN|VAT|NIP|PESEL|REF)$/i.test(b)) sc+=5;
