function runReworkGuard(){
  const sh=active();
  if(!sh||!sh.rows.length){ toast('Brak danych'); return; }
  if(isRegistrySheet(sh)||sh.name===PARK_SHEET){ toast('Strażnik działa na listach roboczych'); return; }
  const keyCi=pickKeyColumnInteractive(sh);
  if(keyCi<0){ toast('Anulowano'); return; }
  pushUndo();
  const warnCi=ensureCol(sh,'Ostrzeżenie',160);
  if(warnCi<0){ toast('Brak miejsca na kolumnę Ostrzeżenie'); return; }
  const reg=getRegistrySheet();
  const by=reg?registryIndexByPesel(reg):new Map();
  const rmap=reg?registryColMap(reg):{};
  const arch=archivePeselSet();
  const parkWait=parkingWaitPeselSet();
  let hits=0;
  sh.rows.forEach((row,ri)=>{
    const key=normPesel(row[keyCi]);
    const flags=[];
    if(key && arch.has(key)) flags.push('Archiwum');
    if(key && parkWait.has(key)) flags.push('parking');
    if(key && by.has(key)){
      const dest=by.get(key);
      const stan=rmap.Stan!=null?norm(reg.rows[dest][rmap.Stan]):'';
      if(stan===REG_STATUS.today || stan===REG_STATUS.ok) flags.push('świeży komplet');
      if(stan===REG_STATUS.overdue) flags.push('>100 dni');
    }
    if(flags.length){
      row[warnCi]=flags.join(' · ');
      sh.rowColors[ri]= flags.includes('Archiwum')||flags.includes('świeży komplet') ? 'red' : 'amber';
      hits++;
    }else{
      row[warnCi]='';
    }
  });
  fitColumnWidths(sh,{wrap:true});
  render();
  toast(hits?('Strażnik: '+hits+' ostrzeżeń'):'Strażnik: czysto');
}

const PANIC_LAW_HTML=`
<h3>DZIAŁ I<br>Przepisy ogólne</h3>
<p>Art. 1. Ustawa normuje postępowanie egzekucyjne w administracji, zwane dalej „postępowaniem egzekucyjnym”, oraz zabezpieczenie wykonania obowiązków podlegających egzekucji administracyjnej.</p>
