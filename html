.grid tbody tr.selected.rc-yellow td,.grid tbody tr.selected.rc-green td,.grid tbody tr.selected.rc-red td,
.grid tbody tr.selected.rc-blue td,.grid tbody tr.selected.rc-purple td,.grid tbody tr.selected.rc-gray td{box-shadow:inset 0 0 0 2px color-mix(in srgb,var(--accent) 55%,transparent)}
.mark-dup{background:#fff3cd!important}.mark-empty{background:#fde2e1!important}
.grid tfoot td{position:sticky;bottom:0;z-index:4;background:var(--panel2);font-weight:800;border-top:2px solid color-mix(in srgb,var(--text) 35%,var(--line));box-shadow:0 -4px 12px rgba(0,0,0,.06)}
.grid tfoot td .cell{font-weight:800;cursor:default}
.grid tfoot td.sum-label .cell{letter-spacing:.01em}
.grid tfoot td.sum-val{border-left:1px solid var(--line);border-right:1px solid var(--line);background:color-mix(in srgb,var(--panel) 70%,var(--soft))}
.grid tfoot td.sum-val .cell{text-align:right;font-variant-numeric:tabular-nums}
.grid.plain tbody tr:nth-child(even) td{background:transparent}
.grid.plain tbody tr:hover td{background:transparent}
.grid.plain thead th,.grid.plain thead th.corner{background:#fff!important;color:#111!important;border:1px solid #333}
