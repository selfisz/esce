function todayISO(){
  const d=new Date();
  const m=String(d.getMonth()+1).padStart(2,'0');
  const day=String(d.getDate()).padStart(2,'0');
  return d.getFullYear()+'-'+m+'-'+day;
}
function normPesel(v){ return norm(v).replace(/\s+/g,'').replace(/-/g,''); }
function parseISODate(s){
  const t=norm(s);
  if(/^\d{4}-\d{2}-\d{2}$/.test(t)){ const d=new Date(t+'T00:00:00'); return isNaN(d)?null:d; }
  const m=t.match(/^(\d{1,2})[./-](\d{1,2})[./-](\d{4})$/);
  if(m){ const d=new Date(+m[3], +m[2]-1, +m[1]); return isNaN(d)?null:d; }
  return null;
}
function daysBetween(a,b){ return Math.floor((b-a)/(24*3600*1000)); }
function looksLikePesel(v){
  const s=norm(v).replace(/[\s-]/g,'');
  return /^\d{11}$/.test(s);
}
function looksLikeNip(v){
  const s=norm(v).replace(/[\s-]/g,'');
  return /^\d{10}$/.test(s);
}
function detectKeyColumnByData(sh){
  if(!sh||!sh.rows.length) return -1;
  const sample=sh.rows.slice(0, Math.min(20, sh.rows.length));
  let bestPesel=-1, bestPeselCount=0;
  let bestNip=-1, bestNipCount=0;
  for(let ci=0; ci<sh.columns.length; ci++){
    let peselCount=0, nipCount=0;
    sample.forEach(row=>{
      const v=row[ci];
      if(looksLikePesel(v)) peselCount++;
      else if(looksLikeNip(v)) nipCount++;
    });
    if(peselCount>bestPeselCount){ bestPeselCount=peselCount; bestPesel=ci; }
    if(nipCount>bestNipCount){ bestNipCount=nipCount; bestNip=ci; }
  }
  const threshold=Math.max(3, sample.length*0.5);
  if(bestPeselCount>=threshold) return bestPesel;
  if(bestNipCount>=threshold) return bestNip;
  return -1;
}
function findKeyColumn(sh){
  if(!sh||!sh.columns.length) return -1;
  if(sh._keyColCache!=null) return sh._keyColCache;
  let i=sh.columns.findIndex(c=>/pesel/i.test(String(c)));
  if(i<0) i=sh.columns.findIndex(c=>/^nip$/i.test(norm(c)));
  if(i<0) i=sh.columns.findIndex(c=>/identyfikator|numer.*id/i.test(norm(c)));
  if(i<0 && isRegistrySheet(sh) && sh.columns.length>=2) i=1;
  if(i<0) i=detectKeyColumnByData(sh);
  return i;
}
/** W trybie Z BAZĄ: dodaj kolumny Stan/Komplet do listy roboczej, żeby widać postęp. */
function finalizeLinkedListAfterPaste(sh){
  if(!sh || isRegistrySheet(sh)) return [];
  const added=[];
  [...REG_SYSTEMS, 'Stan', 'Komplet'].forEach(n=>{
    const had=sh.columns.indexOf(n)>=0;
    const w = (n==='Stan'||n==='Komplet') ? 100 : 90;
    const ci=ensureCol(sh, n, w);
    if(ci>=0 && !had) added.push(n);
  });
  return added;
}

/** Po wklejeniu bazy A–K: A=NIP, B=PESEL, doklej KAWA/JPK… na końcu (nie kasuj A–K). */
function finalizeRegistryAfterPaste(sh){
  if(!sh||!isRegistrySheet(sh) || !sh.columns.length) return {added:[]};
  // A = NIP, B = PESEL (Twoja baza)
  if(sh.columns.length>=1 && !/nip/i.test(String(sh.columns[0])) && !/pesel/i.test(String(sh.columns[0]))){
    sh.columns[0]='NIP';
  }
  if(sh.columns.length>=2 && !/pesel/i.test(String(sh.columns[1]))){
    sh.columns[1]='PESEL';
  }
  const added=[];
  [...REG_SYSTEMS, ...REG_META].forEach(n=>{
    const had=sh.columns.indexOf(n)>=0;
    const ci=ensureCol(sh, n, (n==='Źródła'||n==='Notatka')?160:110);
    if(ci>=0 && !had) added.push(n);
  });
  refreshRegistryDerived(sh);
  return {added};
}
function ensureCol(sh, name, width){
  let ci=sh.columns.indexOf(name);
  if(ci>=0) return ci;
  if(sh.columns.length>=MAX) return -1;
  ci=sh.columns.length;
  sh.columns.push(name);
  sh.order.push(ci);
  sh.visible.push(true);
  sh.widths.push(width||120);
  sh.rows.forEach(r=>{ while(r.length<sh.columns.length) r.push(''); });
  return ci;
}
function getRegistrySheet(){
  let reg=App.sheets.find(s=>s.name===REG_SHEET);
  if(reg) return reg;
  // stara nazwa ze skoroszytów V8
  reg=App.sheets.find(s=>s.name===REG_SHEET_OLD);
  if(reg){ reg.name=REG_SHEET; return reg; }
  return null;
}
function ensureRegistrySheet(switchTo){
  let reg=getRegistrySheet();
  if(!reg){
    const cols=['NIP','PESEL', ...REG_SYSTEMS, ...REG_META];
    reg=newSheet(REG_SHEET, {
      columns:cols,
      rows:[],
      order:cols.map((_,i)=>i),
      visible:cols.map(()=>true),
      widths:cols.map((n)=>n==='PESEL'||n==='NIP'?130:n==='Źródła'||n==='Notatka'?160:100)
    });
    App.sheets.push(reg);
  }else{
    finalizeRegistryAfterPaste(reg);
  }
  if(switchTo) App.activeId=reg.id;
  return reg;
}
function registryColMap(reg){
  const m={};
  reg.columns.forEach((n,i)=>{ m[n]=i; });
  return m;
}
function computePersonStatus(dates){
  const today=todayISO();
  const todayD=parseISODate(today);
  const parsed=dates.map(parseISODate);
  const filled=parsed.filter(Boolean);
  if(!filled.length) return {stan:REG_STATUS.todo, komplet:''};
  if(filled.length<dates.length) return {stan:REG_STATUS.partial, komplet:''};
  const oldest=filled.reduce((a,b)=>a<b?a:b);
  const age=daysBetween(oldest, todayD);
  const komplet=oldest.toISOString().slice(0,10);
  if(age>REG_CYCLE_DAYS) return {stan:REG_STATUS.overdue, komplet};
  if(filled.every(d=>d.toISOString().slice(0,10)===today)) return {stan:REG_STATUS.today, komplet};
  return {stan:REG_STATUS.ok, komplet};
}
function refreshRegistryDerived(reg){
  if(!reg) return;
  const map=registryColMap(reg);
  const sysIdx=REG_SYSTEMS.map(n=>map[n]).filter(i=>i!=null&&i>=0);
  const stanCi=map['Stan'], kompCi=map['Komplet'];
  if(stanCi==null) return;
  reg.rows.forEach((row,ri)=>{
    const dates=sysIdx.map(ci=>row[ci]||'');
    const {stan,komplet}=computePersonStatus(dates);
    row[stanCi]=stan;
    if(kompCi!=null) row[kompCi]=komplet;
    const color=REG_STATUS_COLOR[stan];
    if(color) reg.rowColors[ri]=color; else delete reg.rowColors[ri];
  });
}
function registryIndexByPesel(reg){
  const map=registryColMap(reg);
  const pci=map['PESEL'];
  const idx=new Map();
  if(pci==null) return idx;
  reg.rows.forEach((r,i)=>{
    const k=normPesel(r[pci]);
    if(k) idx.set(k,i);
  });
  return idx;
}
function pickKeyColumnInteractive(sh){
  let ci=findKeyColumn(sh);
  if(ci>=0) return ci;
  if(!sh.columns.length) return -1;
  
  const sample=sh.rows.slice(0, 3);
  const options=sh.order.filter(i=>sh.visible[i]).map(ci=>{
    const colLetter=letter(sh.order.indexOf(ci));
    const colName=sh.columns[ci]||'?';
    const sampleVals=sample.map(r=>String(r[ci]||'').slice(0,15)).join(', ');
    const hint=looksLikePesel(sample[0]?.[ci])?'(wygląda na PESEL)':looksLikeNip(sample[0]?.[ci])?'(wygląda na NIP)':'';
    return `${colLetter}: ${colName} → ${sampleVals} ${hint}`;
  }).join('\n');
  
  const ans=prompt('Która kolumna zawiera PESEL lub NIP?\nWpisz literę kolumny:\n\n'+options, 'A');
  if(ans==null) return -1;
  const letterUp=norm(ans).toUpperCase();
  const orderPos=LETTERS.indexOf(letterUp);
  if(orderPos>=0 && orderPos<sh.order.length){
    sh._keyColCache=sh.order[orderPos];
    return sh._keyColCache;
  }
  const byName=sh.columns.findIndex(c=>norm(c).toLowerCase()===norm(ans).toLowerCase());
  if(byName>=0) sh._keyColCache=byName;
  return byName;
}
function setKeyColumnManual(){
  const sh=active();
  if(!sh||!sh.columns.length){ toast('Brak danych na karcie'); return; }
  
  const sample=sh.rows.slice(0, 3);
  const options=sh.order.filter(i=>sh.visible[i]).map(ci=>{
    const colLetter=letter(sh.order.indexOf(ci));
    const colName=sh.columns[ci]||'?';
    const sampleVals=sample.map(r=>String(r[ci]||'').slice(0,15)).join(', ');
    const hint=looksLikePesel(sample[0]?.[ci])?'← PESEL':looksLikeNip(sample[0]?.[ci])?'← NIP':'';
    return `${colLetter}: ${colName} → ${sampleVals} ${hint}`;
  }).join('\n');
  
  const current=findKeyColumn(sh);
  const currentInfo=current>=0?`\nObecnie: kolumna ${letter(sh.order.indexOf(current))} (${sh.columns[current]})`:'';
  
  const ans=prompt('Która kolumna zawiera PESEL lub NIP?\nWpisz literę kolumny:'+currentInfo+'\n\n'+options, current>=0?letter(sh.order.indexOf(current)):'A');
  if(ans==null) return;
  const letterUp=norm(ans).toUpperCase();
  const orderPos=LETTERS.indexOf(letterUp);
  if(orderPos>=0 && orderPos<sh.order.length){
    sh._keyColCache=sh.order[orderPos];
    toast('Kolumna klucza: '+letterUp+' ('+sh.columns[sh._keyColCache]+')');
  }else{
    toast('Nieprawidłowa kolumna');
  }
}

function appendSourceTag(existing, tag){
  const t=norm(tag); if(!t) return existing||'';
  const parts=String(existing||'').split(';').map(s=>s.trim()).filter(Boolean);
  if(parts.includes(t)) return parts.join('; ');
  parts.push(t);
  return parts.join('; ');
}
/** Znacznik źródła z nazwy listy (+ opcjonalnie systemy). Kolumny listy ≠ kolumny Zobowiązanych. */
function listSourceTag(sh, systems){
  const base=norm(sh&&sh.name?sh.name:'lista')+' '+todayISO();
  if(systems&&systems.length&&systems.length<REG_SYSTEMS.length){
    return base+' ['+systems.join('+')+']';
  }
  if(systems&&systems.length===REG_SYSTEMS.length) return base+' [komplet]';
  return base;
}
function tagPersonSource(reg, destRi, tag){
  if(!reg||destRi==null||destRi<0) return;
  const zci=ensureCol(reg,'Źródła',160);
  if(zci<0) return;
  reg.rows[destRi][zci]=appendSourceTag(reg.rows[destRi][zci], tag);
}
function mergeActiveIntoRegistry(){
  const src=active();
  if(!src||!src.rows.length){ toast('Brak danych do scalenia'); return; }
  if(isRegistrySheet(src)){ toast('Jesteś już w Zobowiązanych'); return; }
  const keyCi=pickKeyColumnInteractive(src);
  if(keyCi<0){ toast('Anulowano — potrzebny klucz PESEL/NIP'); return; }

  pushUndo();
  const reg=ensureRegistrySheet(false);
  ensureCol(reg,'PESEL',130);
  REG_SYSTEMS.forEach(n=>ensureCol(reg,n,100));
  REG_META.forEach(n=>ensureCol(reg,n,160));

  const regMap=registryColMap(reg);
  const pci=regMap['PESEL'];
  const byPesel=registryIndexByPesel(reg);
  const idxs=src.selected.size?[...src.selected].sort((a,b)=>a-b):src.rows.map((_,i)=>i);
  const tag=listSourceTag(src);
  let added=0, updated=0, skipped=0;

  idxs.forEach(ri=>{
    const key=normPesel(src.rows[ri][keyCi]);
    if(!key){ skipped++; return; }
    let destRi=byPesel.get(key);
    if(destRi==null){
      const row=Array.from({length:reg.columns.length},()=>'');
      row[pci]=key;
      destRi=reg.rows.length;
      reg.rows.push(row);
      byPesel.set(key, destRi);
      added++;
    }else updated++;
    // tylko PESEL + ślad źródła — kolumn z listy VAT/Mariusze NIE mieszamy do bazy
    tagPersonSource(reg, destRi, tag);
  });

  refreshRegistryDerived(reg);
  render();
  toast('Zobowiązani: +'+added+' nowych, '+updated+' z tagiem „'+tag+'”'+(skipped?', bez klucza: '+skipped:''));
}
function enrichActiveFromRegistry(){
  const sh=active();
  if(!sh||!sh.rows.length){ toast('Brak danych'); return; }
  const reg=getRegistrySheet();
  if(!reg||!reg.rows.length){ toast('Baza pusta — najpierw Zapamiętaj z listy'); return; }

  const keyCi=pickKeyColumnInteractive(sh);
  if(keyCi<0){ toast('Anulowano — potrzebny klucz'); return; }

  pushUndo();
  if(isRegistrySheet(sh)){
    refreshRegistryDerived(sh);
    render();
    toast('Odświeżono stany w Zobowiązanych');
    return;
  }

  const stanCi=ensureCol(sh,'Stan',120);
  const kompCi=ensureCol(sh,'Komplet',110);
  if(stanCi<0){ toast('Brak miejsca na kolumny (limit A–Z)'); return; }

  const byPesel=registryIndexByPesel(reg);
  const rmap=registryColMap(reg);
  const counts={todo:0, partial:0, overdue:0, ok:0, today:0, unknown:0};

  sh.rows.forEach((row,ri)=>{
    const key=normPesel(row[keyCi]);
    const dest=key?byPesel.get(key):null;
    if(dest==null){
      row[stanCi]=REG_STATUS.todo;
      if(kompCi>=0) row[kompCi]='';
      sh.rowColors[ri]='yellow';
      counts.todo++; counts.unknown++;
      return;
    }
    const dates=REG_SYSTEMS.map(n=>{ const ci=rmap[n]; return ci!=null?(reg.rows[dest][ci]||''):''; });
    const {stan,komplet}=computePersonStatus(dates);
    row[stanCi]=stan;
    if(kompCi>=0) row[kompCi]=komplet;
    const color=REG_STATUS_COLOR[stan];
    if(color) sh.rowColors[ri]=color; else delete sh.rowColors[ri];
    if(stan===REG_STATUS.todo) counts.todo++;
    else if(stan===REG_STATUS.partial) counts.partial++;
    else if(stan===REG_STATUS.overdue) counts.overdue++;
    else if(stan===REG_STATUS.today) counts.today++;
    else counts.ok++;
  });

  fitColumnWidths(sh,{wrap:true});
  render();
  const due=counts.todo+counts.partial+counts.overdue;
  toast('Do zrobienia '+due+' · OK/Dziś '+(counts.ok+counts.today)+' · poza bazą: '+counts.unknown);
}
function markSystemsToday(systems){
  const list=(systems&&systems.length)?systems.slice():REG_SYSTEMS.slice();
  const sh=active();
  if(!sh) return;

  if(App.workMode==='adhoc' && !isRegistrySheet(sh)){
    toast('Włącz tryb „Z bazą" (u góry) aby używać oznaczeń KAWA/JPK…');
    return;
  }

  // na liście roboczej baza tworzy się sama — bez osobnego „Otwórz”
  let reg=isRegistrySheet(sh) ? sh : ensureRegistrySheet(false);
  if(!reg){ toast('Nie udało się utworzyć Zobowiązanych'); return; }

  const idxs=sh.selected.size?[...sh.selected]: (App.activeCell?[App.activeCell.r]:[]);
  if(!idxs.length){ toast('Zaznacz osobę / wiersze (albo kliknij komórkę)'); return; }

  pushUndo();
  const today=todayISO();
  const tag=listSourceTag(sh, list);
  let n=0;

  if(isRegistrySheet(sh)){
    const map=registryColMap(sh);
    idxs.forEach(ri=>{
      list.forEach(name=>{ const ci=map[name]; if(ci!=null) sh.rows[ri][ci]=today; });
      tagPersonSource(sh, ri, tag);
      n++;
    });
    refreshRegistryDerived(sh);
  }else{
    const keyCi=pickKeyColumnInteractive(sh);
    if(keyCi<0){ toast('Anulowano'); return; }
    REG_META.forEach(nm=>ensureCol(reg,nm,160));
    const rmap=registryColMap(reg);
    let byPesel=registryIndexByPesel(reg);
    const pci=rmap['PESEL'];
    idxs.forEach(ri=>{
      const key=normPesel(sh.rows[ri][keyCi]);
      if(!key) return;
      let dest=byPesel.get(key);
      if(dest==null){
        const row=Array.from({length:reg.columns.length},()=>'');
        row[pci]=key;
        dest=reg.rows.length;
        reg.rows.push(row);
        byPesel.set(key, dest);
      }
      list.forEach(name=>{ const ci=rmap[name]; if(ci!=null) reg.rows[dest][ci]=today; });
      tagPersonSource(reg, dest, tag);
      n++;
    });
    refreshRegistryDerived(reg);
    // od razu widać efekt na liście — bez osobnego „Pokaż status”
    const stanCi=ensureCol(sh,'Stan',120);
    const kompCi=ensureCol(sh,'Komplet',110);
    byPesel=registryIndexByPesel(reg);
    idxs.forEach(ri=>{
      const key=normPesel(sh.rows[ri][keyCi]);
      const dest=key?byPesel.get(key):null;
      if(dest==null) return;
      const dates=REG_SYSTEMS.map(name=>reg.rows[dest][rmap[name]]||'');
      const {stan,komplet}=computePersonStatus(dates);
      if(stanCi>=0) sh.rows[ri][stanCi]=stan;
      if(kompCi>=0) sh.rows[ri][kompCi]=komplet;
      sh.rowColors[ri]=REG_STATUS_COLOR[stan]||'blue';
    });
  }
  render();
  const label=list.length===REG_SYSTEMS.length?'Komplet':list.join('+');
  toast(label+' → Zobowiązani ('+n+') · „'+tag+'”');
}
function markCompleteToday(){ markSystemsToday(REG_SYSTEMS); }
function markTrioToday(){ markSystemsToday(['KAWA','JPK','INFZ']); }

function syncListToRegistry(){
  const sh=active();
  if(!sh){ toast('Brak aktywnej karty'); return; }
  if(isRegistrySheet(sh)){ toast('Jesteś już na bazie Zobowiązanych'); return; }
  if(sh.name===PARK_SHEET || sh.name==='Archiwum'){ toast('Synchronizacja działa tylko z list roboczych'); return; }

  const keyCi=findKeyColumn(sh);
  if(keyCi<0){ toast('Brak kolumny PESEL/NIP na liście — nie mogę dopasować osób'); return; }

  const stanCi=sh.columns.indexOf('Stan');
  if(stanCi<0){ toast('Brak kolumny Stan — najpierw użyj oznaczeń KAWA/JPK…'); return; }

  let reg=getRegistrySheet();
  if(!reg){ toast('Brak bazy Zobowiązanych — najpierw stwórz bazę'); return; }

  const rmap=registryColMap(reg);
  const pci=rmap['PESEL'];
  if(pci==null){ toast('Baza nie ma kolumny PESEL'); return; }

  const byPesel=registryIndexByPesel(reg);
  const today=todayISO();
  const tag=listSourceTag(sh, ['SYNC']);

  let updated=0, notInBase=[];

  pushUndo();
  sh.rows.forEach((row, ri)=>{
    const stan=norm(row[stanCi]);
    if(!stan || stan===REG_STATUS.todo) return;

    const key=normPesel(row[keyCi]);
    if(!key) return;

    const dest=byPesel.get(key);
    if(dest==null){
      notInBase.push({ri, key, row: row.slice()});
      return;
    }

    REG_SYSTEMS.forEach(name=>{
      const regCi=rmap[name];
      if(regCi==null) return;
      const current=reg.rows[dest][regCi];
      if(!current || current===''){
        reg.rows[dest][regCi]=today;
      }
    });
    tagPersonSource(reg, dest, tag);
    updated++;
  });

  refreshRegistryDerived(reg);

  if(notInBase.length){
    const names=notInBase.slice(0,5).map(x=>x.key).join(', ')+(notInBase.length>5?'…':'');
    const add=confirm('Znaleziono '+notInBase.length+' osób spoza bazy:\n'+names+'\n\nDodać je do Zobowiązanych?');
    if(add){
      notInBase.forEach(({key, row})=>{
        const newRow=Array.from({length:reg.columns.length},()=>'');
        newRow[pci]=key;
        REG_SYSTEMS.forEach(name=>{
          const regCi=rmap[name];
          if(regCi!=null) newRow[regCi]=today;
        });
        const srcCi=rmap['Źródła'];
        if(srcCi!=null) newRow[srcCi]=tag;
        reg.rows.push(newRow);
        updated++;
      });
      refreshRegistryDerived(reg);
    }
  }

  render();
  toast('Synchronizacja: '+updated+' osób zaktualizowanych w bazie');
}
function addMissingToRegistry(){
  const sh=active();
  if(!sh){ toast('Brak aktywnej karty'); return; }
  if(isRegistrySheet(sh)){ toast('Jesteś na bazie — ta funkcja dodaje z listy do bazy'); return; }
  if(sh.name===PARK_SHEET || sh.name==='Archiwum'){ toast('Działa tylko z list roboczych'); return; }
  if(!sh.rows.length){ toast('Lista jest pusta'); return; }

  const keyCi=findKeyColumn(sh);
  if(keyCi<0){ toast('Brak kolumny PESEL/NIP — nie mogę porównać'); return; }

  let reg=getRegistrySheet();
  if(!reg){
    reg=ensureRegistrySheet(false);
  }
  
  const rmap=registryColMap(reg);
  const pci=rmap['PESEL'];
  if(pci==null){ toast('Baza nie ma kolumny PESEL'); return; }

  const byPesel=registryIndexByPesel(reg);
  
  let added=0, skipped=0;
  const toAdd=[];
  
  sh.rows.forEach((row, ri)=>{
    const key=normPesel(row[keyCi]);
    if(!key){ skipped++; return; }
    if(byPesel.has(key)){ skipped++; return; }
    toAdd.push({key, row: row.slice()});
  });

  if(!toAdd.length){
    toast('Wszystkie osoby z listy są już w bazie ('+skipped+' pominięto)');
    return;
  }

  if(!confirm('Dodać '+toAdd.length+' nowych osób do bazy?\n('+skipped+' już istnieje — nie będą ruszone)')){
    return;
  }

  pushUndo();
  const tag=listSourceTag(sh, []);
  
  toAdd.forEach(({key, row})=>{
    const newRow=Array.from({length:reg.columns.length},()=>'');
    newRow[pci]=key;
    
    // Skopiuj dane z listy do odpowiednich kolumn bazy (jeśli nazwy się zgadzają)
    sh.columns.forEach((colName, ci)=>{
      const regCi=rmap[colName];
      if(regCi!=null && regCi!==pci){
        newRow[regCi]=row[ci]||'';
      }
    });
    
    const srcCi=rmap['Źródła'];
    if(srcCi!=null) newRow[srcCi]=tag;
    
    reg.rows.push(newRow);
    byPesel.set(key, reg.rows.length-1);
    added++;
  });

  refreshRegistryDerived(reg);
  render();
  toast('Dodano '+added+' nowych osób do bazy ('+skipped+' pominięto — już były)');
}

