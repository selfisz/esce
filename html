function getOrCreateArchive(source){
  let arch=App.sheets.find(s=>s.name==='Archiwum');
  if(!arch){
    arch=newSheet('Archiwum');
    arch.columns=['_dataObsługi', ...source.columns];
    arch.order=arch.columns.map((_,i)=>i);
    arch.visible=arch.columns.map(()=>true);
    arch.widths=arch.columns.map((_,i)=>i===0?170:(source.widths[i-1]||150));
    App.sheets.push(arch);
    return arch;
  }
  if(!arch.columns.length || arch.columns[0]!=='_dataObsługi'){
    const rest=arch.columns[0]==='_dataObsługi'?arch.columns.slice(1):arch.columns.slice();
    arch.columns=['_dataObsługi', ...(rest.length?rest:source.columns.slice())];
    arch.order=arch.columns.map((_,i)=>i);
    while(arch.visible.length<arch.columns.length) arch.visible.push(true);
