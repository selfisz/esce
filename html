      <button class="btn sm" id="btnAppend" type="button">Dopisz</button>
      <button class="btn sm" id="btnPasteHere" type="button" title="Wklej od aktywnej komórki">Wklej tu</button>
      <div class="menu-wrap">
        <button class="btn sm" id="btnPasteHist" type="button">Historia ▾</button>
        <div class="menu" id="pasteHistMenu"></div>
      </div>
    </div>
    <div class="ribbon" id="ribbon-edycja" data-panel="edycja" role="tabpanel">
      <button class="btn sm" id="btnFind" type="button">Szukaj/Zamień</button>
