      <button type="button" class="ribbon-tab" data-tab="widok" role="tab">Widok</button>
      <button type="button" class="ribbon-tab" data-tab="zaznaczenie" role="tab">Zaznaczenie</button>
      <button type="button" class="ribbon-tab" data-tab="narzedzia" role="tab">Narzędzia</button>
      <button type="button" class="ribbon-tab" data-tab="rejestr" role="tab" title="Otwiera dolną kartę BAZY. Tu wklejasz zobowiązanych. Raporty dzienne → karta Lista.">Zobowiązani</button>
      <button type="button" class="ribbon-tab" data-tab="eksport" role="tab">Eksport</button>
    </div>
